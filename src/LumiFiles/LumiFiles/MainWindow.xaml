<Window
    x:Class="LumiFiles.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LumiFiles"
    xmlns:models="using:LumiFiles.Models"
    xmlns:viewmodels="using:LumiFiles.ViewModels"
    xmlns:views="using:LumiFiles.Views"
    xmlns:helpers="using:LumiFiles.Helpers"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:spancontrols="using:LumiFiles.Views.Controls"
    xmlns:appcontrols="using:LumiFiles.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- ============================================================
         LUMI FILES — Tahoe Liquid Glass outer composition
         WallpaperRoot: vivid purple gradient (5 radials + base linear),
         visible in the 6px gap on left/top/bottom (right = flush).
         WindowFrame: 24px rounded inner frame holding all UI.
         Sidebar (Layer 2) floats on top of the content (Layer 1).
         ============================================================ -->
    <Grid x:Name="WallpaperRoot">
        <!-- Wallpaper: dark base only (vivid radials disabled — they read as a colored "line"
             in the narrow 6px gap rather than the broad mockup wallpaper). -->
        <Rectangle Fill="{ThemeResource LumiWallpaperBaseBrush}"/>
        <!-- Window inner frame: rounded 24px, padded so wallpaper shows on left/top/bottom (right flush).
             Background semi-transparent (LumiWindowFrameBrush ~0.88-0.94) lets a hint of wallpaper
             bleed through; the sidebar sits floating over this frame at LumiSidebarMargin (6 sides). -->
        <Border x:Name="WindowFrame"
                CornerRadius="{StaticResource LumiWindowCornerRadius}"
                Margin="{StaticResource LumiWindowPadding}"
                Background="{ThemeResource LumiWindowFrameBrush}"
                BorderThickness="0">
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <!-- FileIconConverter removed: icons are now in ViewModels -->
            <helpers:BoolToBrushConverter x:Key="BoolToBrushConverter"
                                          TrueBrush="{ThemeResource SpanAccentDimBrush}"
                                          FalseBrush="Transparent"/>
            <helpers:BoolToThicknessConverter x:Key="BoolToThicknessConverter"
                                              TrueThickness="0,2,1,0"
                                              FalseThickness="0,2,1,0"/>
            <helpers:BoolToThicknessConverter x:Key="MillerColumnBorderConverter"
                                              TrueThickness="1"
                                              FalseThickness="1"/>

            <!-- FontScale 은 App.xaml 의 <helpers:FontScaleService x:Key="FontScale"/> 로 전역 선언됨.
                 {StaticResource FontScale} lookup 은 로컬 RootGrid.Resources → Window 스코프 →
                 Application.Resources 로 walk up 하여 단일 XAML 인스턴스를 찾는다. -->
        </Grid.Resources>

        <!-- LumiFiles Tahoe layout: sidebar spans full window height (4 rows) on the left,
             content (TitleBar/Toolbar/MainArea/StatusBar) flows in column 1 on the right. -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource LumiSidebarGridWidth}"/>  <!-- Lumi Sidebar (full height) -->
            <ColumnDefinition Width="*"/>                                   <!-- Content -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TitleBar -->
            <RowDefinition Height="Auto"/> <!-- Unified Bar -->
            <RowDefinition Height="*"/>    <!-- Main Area -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             LUMI SIDEBAR — floating glass card, 18px radius, full window height
             Mockup-perfect placeholder visual (Stage 3 result).
             Existing per-section bindings still live inside the legacy SidebarBorder
             in Main Area row 2 (collapsed via SidebarCol Width=0) until Stage 4
             rewires data into this new sidebar.
             ============================================================ -->
        <Border x:Name="LumiSidebar"
                Grid.Column="0" Grid.Row="0" Grid.RowSpan="4"
                Margin="{StaticResource LumiSidebarMargin}"
                CornerRadius="{StaticResource LumiSidebarCornerRadius}"
                Background="{ThemeResource LumiSidebarBrush}"
                BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{StaticResource LumiSidebarTopGridHeight}"/>  <!-- Logo + name (drag region) -->
                    <RowDefinition Height="*"/>                                       <!-- Sections -->
                    <RowDefinition Height="Auto"/>                                    <!-- Settings -->
                </Grid.RowDefinitions>

                <!-- Top: amber gradient logo + "Lumi Files" name -->
                <Grid Grid.Row="0" Padding="16,0" ColumnSpacing="7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="4"
                            Background="{ThemeResource LumiCatAmberBrush}" VerticalAlignment="Center">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                    </Border>
                    <TextBlock Grid.Column="1" Text="Lumi Files"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource LumiFontFamily}"
                               FontSize="{StaticResource LumiFontSizeSbName}"
                               FontWeight="Medium"
                               Foreground="{ThemeResource LumiTextSecondaryBrush}"/>
                </Grid>

                <!-- Body: dynamic bindings — Favorites / Local Drives / Cloud / Network -->
                <ScrollViewer Grid.Row="1" Padding="8,4,8,10" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="6">

                        <!-- ===== Favorites (Windows quick-access bookmarks via ViewModel.Favorites) ===== -->
                        <StackPanel>
                            <Grid Padding="4,10,4,3" Background="Transparent"
                                  Tapped="OnSidebarSectionToggle" Tag="Favorites">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Favorites"
                                           FontFamily="{StaticResource LumiFontFamily}"
                                           FontSize="{StaticResource LumiFontSizeSbHeader}"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource LumiTextSecondaryBrush}"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE70D;" FontSize="10"
                                          Foreground="{ThemeResource LumiTextSecondaryBrush}"
                                          RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsFavoritesExpanded), Mode=OneWay}"/>
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Favorites, Mode=OneWay}"
                                          Visibility="{x:Bind helpers:ConverterHelpers.BoolToVisibility(ViewModel.IsFavoritesExpanded), Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:FavoriteItem">
                                        <Grid Padding="10,5" CornerRadius="{StaticResource LumiSidebarItemCornerRadius}" ColumnSpacing="9"
                                              Background="Transparent"
                                              ToolTipService.ToolTip="{x:Bind Path}"
                                              Tapped="OnLumiFavoriteItemTapped"
                                              Tag="{x:Bind Path}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Folder}"
                                                      FontSize="14" VerticalAlignment="Center"
                                                      Foreground="{ThemeResource LumiFolderDefaultBrush}" Opacity="0.85"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"
                                                       FontFamily="{StaticResource LumiFontFamily}"
                                                       FontSize="{StaticResource LumiFontSizeBase}"
                                                       Foreground="{ThemeResource LumiTextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ===== Local Drives (ViewModel.Drives, filtered by IsNetworkDrive=false via DataTemplate Visibility) ===== -->
                        <StackPanel>
                            <Grid Padding="4,10,4,3" Background="Transparent"
                                  Tapped="OnSidebarSectionToggle" Tag="Local">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Local Drives"
                                           FontFamily="{StaticResource LumiFontFamily}"
                                           FontSize="{StaticResource LumiFontSizeSbHeader}"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource LumiTextSecondaryBrush}"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE70D;" FontSize="10"
                                          Foreground="{ThemeResource LumiTextSecondaryBrush}"
                                          RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsLocalDrivesExpanded), Mode=OneWay}"/>
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}"
                                          Visibility="{x:Bind helpers:ConverterHelpers.BoolToVisibility(ViewModel.IsLocalDrivesExpanded), Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveItem">
                                        <Grid Padding="10,5" CornerRadius="{StaticResource LumiSidebarItemCornerRadius}" ColumnSpacing="9"
                                              Background="Transparent"
                                              ToolTipService.ToolTip="{x:Bind TooltipText}"
                                              Tapped="OnLumiDriveItemTapped"
                                              Visibility="{x:Bind helpers:ConverterHelpers.NotNetworkDriveVisibility(IsNetworkDrive)}"
                                              Tag="{x:Bind Path}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind IconGlyph}"
                                                       FontFamily="{StaticResource RemixIcons}" FontSize="14"
                                                       Foreground="{ThemeResource LumiTextSecondaryBrush}" Opacity="0.85"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"
                                                       FontFamily="{StaticResource LumiFontFamily}"
                                                       FontSize="{StaticResource LumiFontSizeBase}"
                                                       Foreground="{ThemeResource LumiTextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ===== Cloud (only when ViewModel.HasCloudDrives) ===== -->
                        <StackPanel Visibility="{x:Bind ViewModel.HasCloudDrives, Mode=OneWay}">
                            <Grid Padding="4,10,4,3" Background="Transparent"
                                  Tapped="OnSidebarSectionToggle" Tag="Cloud">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Cloud"
                                           FontFamily="{StaticResource LumiFontFamily}"
                                           FontSize="{StaticResource LumiFontSizeSbHeader}"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource LumiTextSecondaryBrush}"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE70D;" FontSize="10"
                                          Foreground="{ThemeResource LumiTextSecondaryBrush}"
                                          RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsCloudDrivesExpanded), Mode=OneWay}"/>
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CloudDrives, Mode=OneWay}"
                                          Visibility="{x:Bind helpers:ConverterHelpers.BoolToVisibility(ViewModel.IsCloudDrivesExpanded), Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveItem">
                                        <Grid Padding="10,5" CornerRadius="{StaticResource LumiSidebarItemCornerRadius}" ColumnSpacing="9"
                                              Background="Transparent"
                                              ToolTipService.ToolTip="{x:Bind TooltipText}"
                                              Tapped="OnLumiDriveItemTapped"
                                              Tag="{x:Bind Path}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="20" Height="20"
                                                    CornerRadius="{StaticResource LumiSidebarIconCornerRadius}"
                                                    Background="{ThemeResource LumiCatBlueBrush}">
                                                <TextBlock Text="{x:Bind IconGlyph}" FontFamily="{StaticResource RemixIcons}"
                                                           FontSize="11" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"
                                                       FontFamily="{StaticResource LumiFontFamily}"
                                                       FontSize="{StaticResource LumiFontSizeBase}"
                                                       Foreground="{ThemeResource LumiTextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ===== Network (only when ViewModel.HasNetworkDrives) ===== -->
                        <StackPanel Visibility="{x:Bind ViewModel.HasNetworkDrives, Mode=OneWay}">
                            <Grid Padding="4,10,4,3" Background="Transparent"
                                  Tapped="OnSidebarSectionToggle" Tag="Network">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Network"
                                           FontFamily="{StaticResource LumiFontFamily}"
                                           FontSize="{StaticResource LumiFontSizeSbHeader}"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource LumiTextSecondaryBrush}"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE70D;" FontSize="10"
                                          Foreground="{ThemeResource LumiTextSecondaryBrush}"
                                          RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsNetworkDrivesExpanded), Mode=OneWay}"/>
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.NetworkDrives, Mode=OneWay}"
                                          Visibility="{x:Bind helpers:ConverterHelpers.BoolToVisibility(ViewModel.IsNetworkDrivesExpanded), Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveItem">
                                        <Grid Padding="10,5" CornerRadius="{StaticResource LumiSidebarItemCornerRadius}" ColumnSpacing="9"
                                              Background="Transparent"
                                              ToolTipService.ToolTip="{x:Bind TooltipText}"
                                              Tapped="OnLumiDriveItemTapped"
                                              Tag="{x:Bind Path}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="20" Height="20"
                                                    CornerRadius="{StaticResource LumiSidebarIconCornerRadius}"
                                                    Background="{ThemeResource LumiCatGrayBrush}">
                                                <TextBlock Text="{x:Bind IconGlyph}" FontFamily="{StaticResource RemixIcons}"
                                                           FontSize="11" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"
                                                       FontFamily="{StaticResource LumiFontFamily}"
                                                       FontSize="{StaticResource LumiFontSizeBase}"
                                                       Foreground="{ThemeResource LumiTextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ===== Recycle Bin (Span-original sidebar entry, restored) =====
                             Tap → OnRecycleBinTapped (existing handler in MainWindow.SettingsHandler.cs).
                             Drop → OnRecycleBinDrop (existing handler in MainWindow.DragDropHandler.cs).
                             Icon glyph swaps between empty/full via ViewModel.RecycleBinIconGlyph.
                             Item count badge hides when bin is empty (NotBoolToVisibility on RecycleBinIsEmpty). -->
                        <Rectangle Height="1" Fill="{ThemeResource LumiDividerSoftBrush}" Margin="4,12,4,8"/>
                        <Grid Padding="10,5" CornerRadius="{StaticResource LumiSidebarItemCornerRadius}" ColumnSpacing="9"
                              Background="Transparent"
                              ToolTipService.ToolTip="Recycle Bin"
                              Tapped="OnRecycleBinTapped"
                              AllowDrop="True"
                              DragOver="OnRecycleBinDragOver"
                              Drop="OnRecycleBinDrop"
                              AutomationProperties.AutomationId="LumiSidebar_RecycleBin">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="20" Height="20"
                                    CornerRadius="{StaticResource LumiSidebarIconCornerRadius}"
                                    Background="{ThemeResource LumiCatGrayBrush}">
                                <TextBlock Text="{x:Bind ViewModel.RecycleBinIconGlyph, Mode=OneWay}"
                                           FontFamily="{StaticResource RemixIcons}"
                                           FontSize="11" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Recycle Bin" VerticalAlignment="Center"
                                       FontFamily="{StaticResource LumiFontFamily}"
                                       FontSize="{StaticResource LumiFontSizeBase}"
                                       Foreground="{ThemeResource LumiTextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <Border Grid.Column="2"
                                    Visibility="{x:Bind helpers:ConverterHelpers.NotBoolToVisibility(ViewModel.RecycleBinIsEmpty), Mode=OneWay}"
                                    Background="{ThemeResource LumiHoverBrush}"
                                    CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.RecycleBinItemCount, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource LumiTextSecondaryBrush}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: Settings -->
                <Border Grid.Row="2" Padding="8,6,8,8" BorderBrush="{ThemeResource LumiDividerSoftBrush}" BorderThickness="0,1,0,0">
                    <Grid Padding="10,5" CornerRadius="{StaticResource LumiSidebarItemCornerRadius}" ColumnSpacing="9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE713;" FontSize="15"
                                  Foreground="{ThemeResource LumiTextSecondaryBrush}" Opacity="0.85"/>
                        <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center"
                                   FontFamily="{StaticResource LumiFontFamily}"
                                   FontSize="{StaticResource LumiFontSizeBase}"
                                   Foreground="{ThemeResource LumiTextSecondaryBrush}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================================
             LUMI TOOLBAR — compact pill groups (mockup Stage 6 placeholder).
             Visible in BOTH single and split modes (Stage S-1, option A): split-view
             keeps the same shared toolbar, binding to ActiveExplorer / ActivePane so
             actions follow the focused pane. Per-pane mini headers are being removed
             in subsequent stages (S-2, S-3) of this refactor.
             ============================================================ -->
        <Grid Grid.Column="1" Grid.Row="1" Height="{StaticResource LumiToolbarHeight}" Padding="14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Back/Forward pill -->
                <ColumnDefinition Width="Auto"/>  <!-- Address folder -->
                <ColumnDefinition Width="*"/>     <!-- Spacer -->
                <ColumnDefinition Width="Auto"/>  <!-- View group -->
                <ColumnDefinition Width="Auto"/>  <!-- Tools group -->
                <ColumnDefinition Width="Auto"/>  <!-- Sort group -->
                <ColumnDefinition Width="Auto"/>  <!-- Other group (preview / split) -->
                <ColumnDefinition Width="Auto"/>  <!-- Search group -->
            </Grid.ColumnDefinitions>

            <!-- Back / Forward — segmented bar inside a 1px hairline group outline (rounded rect). -->
            <Border Grid.Column="0" Height="30" Padding="3"
                    CornerRadius="{StaticResource LumiPillFrameCornerRadius}"
                    Background="{ThemeResource LumiPillBrush}"
                    BorderThickness="0"
                    VerticalAlignment="Center" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonLeftCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Back (Alt+Left)"
                            Tag="Left" Click="OnPaneGoBackClick">
                        <FontIcon Glyph="&#xE72B;" FontSize="11"/>
                    </Button>
                    <Rectangle Width="1" Height="14" Fill="{ThemeResource LumiDividerBrush}" VerticalAlignment="Center"/>
                    <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonRightCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Forward (Alt+Right)"
                            Tag="Left" Click="OnPaneGoForwardClick">
                        <FontIcon Glyph="&#xE72A;" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Address folder — shows the CURRENT folder name. Bound directly to
                 ExplorerViewModel.CurrentFolderName (ObservableProperty notified via
                 NotifyPropertyChangedFor on CurrentPath). -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7"
                        VerticalAlignment="Center" Padding="10,0,12,0">
                <FontIcon Glyph="&#xE8B7;" FontSize="14" Foreground="{ThemeResource LumiAmberBrush}"/>
                <TextBlock x:Name="LumiAddressLabel"
                           Text="{x:Bind ViewModel.ActiveExplorer.CurrentFolderName, Mode=OneWay}"
                           FontFamily="{StaticResource LumiFontFamily}"
                           FontSize="{StaticResource LumiFontSizeBase}"
                           FontWeight="Medium"
                           Foreground="{ThemeResource LumiTextPrimaryBrush}"/>
            </StackPanel>

            <!-- ====== Group 1: VIEW — segmented bar inside hairline group outline (rounded rect) ====== -->
            <Border Grid.Column="3" Height="30" Padding="3"
                    CornerRadius="{StaticResource LumiPillFrameCornerRadius}"
                    Background="{ThemeResource LumiPillBrush}"
                    BorderThickness="0"
                    VerticalAlignment="Center" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="LumiViewMillerButton" Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonLeftCornerRadius}"
                            Background="{ThemeResource LumiPillActiveBrush}"
                            Foreground="{ThemeResource LumiAmberSoftBrush}"
                            ToolTipService.ToolTip="Miller Columns" Click="OnViewModeMillerColumns">
                        <FontIcon x:Name="LumiViewMillerIcon" Glyph="&#xF57C;" FontSize="13"/>
                    </Button>
                    <Button x:Name="LumiViewDetailsButton" Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Details" Click="OnViewModeDetails">
                        <FontIcon x:Name="LumiViewDetailsIcon" Glyph="&#xE8FD;" FontSize="13"/>
                    </Button>
                    <Button x:Name="LumiViewIconsButton" Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonRightCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Icons" Click="OnViewModeIconLarge">
                        <FontIcon x:Name="LumiViewIconsIcon" Glyph="&#xF0E2;" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ====== Group 2: TOOLS — segmented bar inside hairline group outline (rounded rect) ====== -->
            <Border Grid.Column="4" Height="30" Padding="3"
                    CornerRadius="{StaticResource LumiPillFrameCornerRadius}"
                    Background="{ThemeResource LumiPillBrush}"
                    BorderThickness="0"
                    VerticalAlignment="Center" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonLeftCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="New folder (Ctrl+Shift+N)" Click="OnNewFolderClick">
                        <FontIcon Glyph="&#xE710;" FontSize="13"/>
                    </Button>
                    <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Delete (Del)" Click="OnDeleteClick">
                        <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                    </Button>
                    <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Cut (Ctrl+X)" Click="OnCutClick">
                        <FontIcon Glyph="&#xE8C6;" FontSize="13"/>
                    </Button>
                    <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Paste (Ctrl+V)" Click="OnPasteClick">
                        <FontIcon Glyph="&#xE77F;" FontSize="13"/>
                    </Button>
                    <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonRightCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Rename (F2)" Click="OnRenameClick">
                        <FontIcon Glyph="&#xE8AC;" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ====== Group 3: SORT — single circular button inside hairline group outline (rounded rect) ====== -->
            <Border Grid.Column="5" Height="30" Padding="3"
                    CornerRadius="{StaticResource LumiPillFrameCornerRadius}"
                    Background="{ThemeResource LumiPillBrush}"
                    BorderThickness="0"
                    VerticalAlignment="Center" Margin="0,0,8,0">
                <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                        CornerRadius="{StaticResource LumiPillButtonCornerRadius}"
                        Background="Transparent"
                        Foreground="{ThemeResource LumiTextPrimaryBrush}"
                        ToolTipService.ToolTip="Sort">
                    <FontIcon Glyph="&#xE8CB;" FontSize="13"/>
                </Button>
            </Border>

            <!-- ====== Group 4: OTHER — segmented bar inside hairline group outline (rounded rect) ====== -->
            <Border Grid.Column="6" Height="30" Padding="3"
                    CornerRadius="{StaticResource LumiPillFrameCornerRadius}"
                    Background="{ThemeResource LumiPillBrush}"
                    BorderThickness="0"
                    VerticalAlignment="Center" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonLeftCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Preview pane" Click="OnPreviewToggleClick">
                        <FontIcon Glyph="&#xE890;" FontSize="13"/>
                    </Button>
                    <Button Width="24" Height="24" Padding="0" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonRightCornerRadius}"
                            Background="Transparent"
                            Foreground="{ThemeResource LumiTextPrimaryBrush}"
                            ToolTipService.ToolTip="Split view" Click="OnSplitViewToggleClick">
                        <FontIcon Glyph="&#xE78D;" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ====== Group 5: SEARCH — circular button toggles to a flat rectangular textbox.
                 Button: 32x32 stadium wrapped in 3px group frame (matches other groups).
                 Expanded textbox: rectangular (CornerRadius 0) per user spec — avoids the
                 awkward stretched-stadium look at 250x28 proportions. ====== -->
            <Grid Grid.Column="7" VerticalAlignment="Center">
                <!-- Collapsed: circular icon button + hairline group outline (rounded rect) -->
                <Border x:Name="LumiSearchButtonFrame" Height="30" Padding="3"
                        CornerRadius="{StaticResource LumiPillFrameCornerRadius}"
                        Background="{ThemeResource LumiPillBrush}"
                        BorderThickness="0"
                        VerticalAlignment="Center">
                    <Button x:Name="LumiSearchButton" Width="24" Height="24" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            CornerRadius="{StaticResource LumiPillButtonCornerRadius}"
                            Foreground="{ThemeResource LumiTextTertiaryBrush}"
                            ToolTipService.ToolTip="Search (Ctrl+F)"
                            Click="OnLumiSearchClick">
                        <FontIcon Glyph="&#xE721;" FontSize="13"/>
                    </Button>
                </Border>
                <!-- Expanded: search box matched to the other toolbar groups — outer stadium
                     (CornerRadius 16, Height 30, Padding 3) so the LEFT search icon + RIGHT
                     close button hug the rounded ends, while the middle TextBox fills the
                     straight section. Same fill-only Finder pattern (no outline). -->
                <Border x:Name="LumiSearchExpanded" Width="250" Height="30" Padding="3" Visibility="Collapsed"
                        CornerRadius="{StaticResource LumiPillFrameCornerRadius}"
                        Background="{ThemeResource LumiPillBrush}"
                        BorderThickness="0"
                        VerticalAlignment="Center">
                    <Grid Padding="9,0,3,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="12"
                                  Foreground="{ThemeResource LumiTextTertiaryBrush}"
                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="LumiSearchInput" Grid.Column="1"
                                 PlaceholderText="Search (Ctrl+F)"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="{StaticResource LumiFontFamily}"
                                 FontSize="{StaticResource LumiFontSizeBase}"
                                 Foreground="{ThemeResource LumiTextPrimaryBrush}"
                                 VerticalAlignment="Center" MinHeight="0"
                                 KeyDown="OnLumiSearchInputKeyDown"
                                 LostFocus="OnLumiSearchInputLostFocus"/>
                        <Button Grid.Column="2" Width="22" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                Background="Transparent" BorderThickness="0"
                                CornerRadius="{StaticResource LumiPillButtonCornerRadius}"
                                Foreground="{ThemeResource LumiTextTertiaryBrush}"
                                ToolTipService.ToolTip="Close (Esc)"
                                Click="OnLumiSearchCloseClick">
                            <FontIcon Glyph="&#xE711;" FontSize="10"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 1. Title Bar (column 1, row 0) — transparent so the window frame shows through (mockup) -->
        <Grid x:Name="AppTitleBar" Grid.Column="1" Height="{StaticResource TitleBarHeight}" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0"/> <!-- 캡션 버튼 여백 (코드에서 설정) -->
            </Grid.ColumnDefinitions>

            <!-- Bottom border line removed (mockup has no titlebar bottom rule) -->
            <Rectangle Grid.ColumnSpan="3" Height="1" VerticalAlignment="Bottom"
                       Fill="Transparent"/>

            <!-- App icon + title removed: LumiSidebar already shows the logo + name (mockup) -->
            <StackPanel x:Name="AppTitleStack" Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center" Margin="0" Visibility="Collapsed">
                <TextBlock x:Name="AppTitleText" Text="Lumi Files" Visibility="Collapsed"/>
            </StackPanel>
            
            <!-- Dynamic Tabs -->
            <ScrollViewer x:Name="TabScrollViewer" Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Auto" VerticalScrollMode="Disabled">
                <Grid>
                <StackPanel x:Name="TabBarContent" Orientation="Horizontal" Spacing="1">
                    <ItemsRepeater x:Name="TabRepeater" AutomationProperties.AutomationId="TabRepeater" ItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="0"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:TabItem">
                                <Grid Height="26" VerticalAlignment="Center" Margin="2,0,0,0" MinWidth="100" MaxWidth="170"
                                      Background="Transparent" CornerRadius="{StaticResource LumiTabCornerRadius}"
                                      PointerPressed="OnTabItemPointerPressed"
                                      PointerMoved="OnTabItemPointerMoved"
                                      PointerReleased="OnTabItemPointerReleased"
                                      RightTapped="OnTabRightTapped"
                                      Tag="{x:Bind}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Active tab background: amber gradient (mockup) -->
                                    <Border Grid.ColumnSpan="2" Background="{ThemeResource LumiTabActiveBrush}"
                                            CornerRadius="{StaticResource LumiTabCornerRadius}"
                                            Visibility="{x:Bind IsActiveVisible, Mode=OneWay}"/>
                                    <Grid Grid.Column="0" VerticalAlignment="Center" Padding="12,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Icons — mockup spec: a single amber color dot only (mode icons removed) -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Fill="{ThemeResource LumiAmberBrush}"
                                                     Opacity="0.85" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Tab name (Star width → TextTrimming works) -->
                                        <TextBlock Grid.Column="1" Text="{x:Bind Header, Mode=OneWay}"
                                                   FontSize="12" Foreground="{ThemeResource SpanTextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                    </Grid>
                                    <!-- Close button — mockup 14x14 -->
                                    <Button Grid.Column="1" Style="{StaticResource UnifiedButtonStyle}"
                                            Width="14" Height="14" Padding="0" MinWidth="0" MinHeight="0"
                                            Margin="0,0,6,0" VerticalAlignment="Center"
                                            Background="Transparent" BorderThickness="0"
                                            Click="OnTabCloseClick" Tag="{x:Bind}">
                                        <FontIcon Glyph="&#xE711;" FontSize="9"
                                                  Foreground="{ThemeResource LumiTextTertiaryBrush}"/>
                                    </Button>
                                    <!-- Inactive tab: no border (mockup) -->
                                    <Border Grid.ColumnSpan="2" BorderBrush="Transparent"
                                            BorderThickness="0" CornerRadius="{StaticResource LumiTabCornerRadius}" IsHitTestVisible="False"
                                            Visibility="{x:Bind IsInactiveVisible, Mode=OneWay}"/>
                                    <!-- Active tab: thin amber inset border -->
                                    <Border Grid.ColumnSpan="2" BorderBrush="{ThemeResource LumiTabActiveBorderBrush}"
                                            BorderThickness="1" CornerRadius="{StaticResource LumiTabCornerRadius}" IsHitTestVisible="False"
                                            Visibility="{x:Bind IsActiveVisible, Mode=OneWay}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- New Tab button -->
                    <Button x:Name="NewTabButton" AutomationProperties.AutomationId="Button_NewTab" Style="{StaticResource UnifiedButtonStyle}" Width="34" Height="34" VerticalAlignment="Bottom"
                            Margin="2,0,0,0" Click="OnNewTabClick" ToolTipService.ToolTip="New Tab (Ctrl+T)">
                        <FontIcon Glyph="&#xE710;" FontSize="12"/>
                    </Button>
                </StackPanel>
                <!-- Ghost tab indicator for re-docking (overlaid on tab bar) -->
                <Border x:Name="GhostTabIndicator" Visibility="Collapsed"
                        Height="34" VerticalAlignment="Bottom"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource SpanAccentBrush}" Opacity="0.15"
                        BorderBrush="{ThemeResource SpanAccentBrush}" BorderThickness="1.5"
                        CornerRadius="6,6,0,0" IsHitTestVisible="False"/>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Settings/ActionLog 모드: 타이틀바 하단 액센트 라인을 덮어 탭↔콘텐츠 연결감 유지
        <Border Grid.Row="1" Height="4" Background="{ThemeResource SpanBgLayer1Brush}"
                BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1"
                Visibility="{x:Bind IsSettingsOrActionLogMode(ViewModel.CurrentViewMode), Mode=OneWay}"/> -->

        <!-- 2. Unified Bar — LEGACY (visually collapsed; bindings preserved for nav/search/address actions
             until Stage 6 wires them into LumiToolbar below) -->
        <Grid x:Name="LegacyUnifiedBar" Grid.Column="1" Grid.Row="1" Height="0" Visibility="Collapsed"
              Background="{ThemeResource SpanBgLayer1Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
              BorderThickness="{x:Bind UnifiedBarBorderThickness(ViewModel.IsSplitViewEnabled), Mode=OneWay}" Padding="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Nav Buttons -->
                <ColumnDefinition Width="*"/>    <!-- Address Bar -->
                <ColumnDefinition Width="Auto"/> <!-- Commands -->
            </Grid.ColumnDefinitions>

            <!-- Nav Buttons (single mode, hidden in Settings) -->
            <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,8,0"
                        Visibility="{x:Bind IsSingleNonSettingsVisible(ViewModel.IsSplitViewEnabled, ViewModel.CurrentViewMode), Mode=OneWay}">
                <Button x:Name="BackButton" AutomationProperties.AutomationId="Button_Back" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="뒤로 (Alt+Left)"
                        IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}" Click="OnGoBackClick"
                        RightTapped="OnBackButtonRightTapped">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Back}" FontSize="14"/>
                </Button>
                <Button x:Name="ForwardButton" AutomationProperties.AutomationId="Button_Forward" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="앞으로 (Alt+Right)"
                        IsEnabled="{x:Bind ViewModel.CanGoForward, Mode=OneWay}" Click="OnGoForwardClick"
                        RightTapped="OnForwardButtonRightTapped">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Forward}" FontSize="14"/>
                </Button>
                <Button x:Name="UpButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="위로" Click="OnNavigateUpClick">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Up}" FontSize="14"/>
                </Button>
            </StackPanel>

            <!-- Address Bar (single mode, hidden in Settings) -->
            <Grid x:Name="AddressBarContainer" AutomationProperties.AutomationId="AddressBar" Grid.Column="1" Height="32"
                  Background="{ThemeResource SpanBgLayer2Brush}"
                  CornerRadius="4" VerticalAlignment="Center"
                  Padding="4,0"
                  Visibility="{x:Bind IsSingleNonSettingsVisible(ViewModel.IsSplitViewEnabled, ViewModel.CurrentViewMode), Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Home icon (visible only in Home mode, controlled via code-behind) -->
                <StackPanel x:Name="HomeAddressIcon" Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Visibility="Collapsed" Margin="4,0,0,0">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Home}" FontSize="13"
                              Foreground="{ThemeResource SpanAccentBrush}"
                              VerticalAlignment="Center" Margin="0,3,0,0"/>
                    <FontIcon Glyph="&#xE76C;" FontSize="8"
                              Foreground="{ThemeResource SpanTextTertiaryBrush}"
                              VerticalAlignment="Center" Margin="4,3,2,0"/>
                </StackPanel>
                <!-- RecycleBin icon (visible only in RecycleBin mode, controlled via code-behind) -->
                <StackPanel x:Name="RecycleBinAddressIcon" Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Visibility="Collapsed" Margin="4,0,0,0">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="&#xEC2A;" FontSize="13"
                              Foreground="{ThemeResource SpanAccentBrush}"
                              VerticalAlignment="Center" Margin="0,3,0,0"/>
                    <FontIcon Glyph="&#xE76C;" FontSize="8"
                              Foreground="{ThemeResource SpanTextTertiaryBrush}"
                              VerticalAlignment="Center" Margin="4,3,2,0"/>
                </StackPanel>

                <appcontrols:AddressBarControl x:Name="MainAddressBar" Grid.Column="1"
                    RecentFolders="{x:Bind ViewModel.RecentFolders, Mode=OneWay}"
                    BreadcrumbSegmentClicked="OnAddressBarBreadcrumbClicked"
                    BreadcrumbChevronClicked="OnAddressBarChevronClicked"
                    PathNavigated="OnAddressBarPathNavigated"/>

                <!-- 경로 복사 버튼 -->
                <Button x:Name="CopyPathButton" AutomationProperties.AutomationId="Button_CopyPath" Grid.Column="2"
                        Style="{StaticResource UnifiedButtonStyle}"
                        ToolTipService.ToolTip="경로 복사"
                        Click="OnCopyPathClick"
                        Padding="4,4" MinWidth="0" MinHeight="0"
                        Margin="2,0,0,0">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Copy}" FontSize="12"/>
                </Button>
            </Grid>

            <!-- Commands -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="8,0,0,0">
                <!-- ═══ Normal Commands (hidden in RecycleBin/Settings/ActionLog) ═══ -->
                <StackPanel Orientation="Horizontal" Spacing="2"
                            Visibility="{x:Bind IsNotSpecialMode(ViewModel.CurrentViewMode), Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="0"
                                Background="Transparent" CornerRadius="4">
                        <Button x:Name="NewFolderButton" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="새 폴더 (Ctrl+Shift+N)"
                                Click="OnNewFolderClick"
                                Padding="8,4,4,4">
                            <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_NewFolder}" FontSize="16"/>
                        </Button>
                        <Button x:Name="NewItemDropdown" AutomationProperties.AutomationId="Button_NewItemDropdown"
                                Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="새로 만들기..."
                                Click="OnNewItemDropdownClick"
                                Padding="2,4,4,4"
                                MinWidth="0">
                            <FontIcon Glyph="&#xE70D;" FontSize="8"/>
                        </Button>
                    </StackPanel>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                    <Button x:Name="ToolbarCutButton" AutomationProperties.AutomationId="Button_Cut" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="잘라내기 (Ctrl+X)" Click="OnCutClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Cut}"/></Button>
                    <Button x:Name="ToolbarCopyButton" AutomationProperties.AutomationId="Button_Copy" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="복사 (Ctrl+C)" Click="OnCopyClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Copy}"/></Button>
                    <Button x:Name="ToolbarPasteButton" AutomationProperties.AutomationId="Button_Paste" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="붙여넣기 (Ctrl+V)" Click="OnPasteClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Paste}"/></Button>
                    <Button x:Name="ToolbarRenameButton" AutomationProperties.AutomationId="Button_Rename" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="이름 바꾸기 (F2)" Click="OnRenameClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Rename}"/></Button>
                    <Button x:Name="ToolbarDeleteButton" AutomationProperties.AutomationId="Button_Delete" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="삭제 (Del)" Click="OnDeleteClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Delete}"/></Button>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>

                <!-- Sort Button with Dropdown -->
                    <Button x:Name="SortButton" AutomationProperties.AutomationId="Button_Sort" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="정렬"
                            Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom" Opening="OnSortMenuOpening">
                                <MenuFlyoutItem x:Name="SortByNameItem" Text="이름" Click="OnSortByName"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C1;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="SortByDateItem" Text="날짜" Click="OnSortByDate"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE787;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="SortBySizeItem" Text="크기" Click="OnSortBySize"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="SortByTypeItem" Text="종류" Click="OnSortByType"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FD;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem x:Name="SortAscendingItem" Text="오름차순" Click="OnSortAscending"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74A;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="SortDescendingItem" Text="내림차순" Click="OnSortDescending"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74B;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutSubItem x:Name="GroupBySubMenu" Text="그룹화"><MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xF168;"/></MenuFlyoutSubItem.Icon>
                                    <MenuFlyoutItem x:Name="GroupByNoneItem" Text="없음" Click="OnGroupByNone"/>
                                    <MenuFlyoutItem x:Name="GroupByNameItem" Text="이름" Click="OnGroupByName"/>
                                    <MenuFlyoutItem x:Name="GroupByTypeItem" Text="종류" Click="OnGroupByType"/>
                                    <MenuFlyoutItem x:Name="GroupByDateItem" Text="날짜" Click="OnGroupByDate"/>
                                    <MenuFlyoutItem x:Name="GroupBySizeItem" Text="크기" Click="OnGroupBySize"/>
                                </MenuFlyoutSubItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon x:Name="SortIcon" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Sort}" FontSize="14"/>
                            <FontIcon x:Name="SortDirectionIcon" Glyph="&#xE74A;" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ViewModeButton" AutomationProperties.AutomationId="Button_ViewMode" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="보기 전환"
                            Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom" Opening="OnMainViewModeMenuOpening">
                                <MenuFlyoutItem x:Name="MainVm_Miller" Text="Miller Columns" Click="OnViewModeMillerColumns"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xF0E2;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="MainVm_Details" Text="Details" Click="OnViewModeDetails"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8EF;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem x:Name="MainVm_List" Text="List" Click="OnViewModeList"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE80A;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutSubItem x:Name="MainVm_Icons" Text="Icons"><MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutSubItem.Icon>
                                    <MenuFlyoutItem x:Name="MainVm_ExtraLarge" Text="Extra Large Icons" Click="OnViewModeIconExtraLarge"/>
                                    <MenuFlyoutItem x:Name="MainVm_Large" Text="Large Icons" Click="OnViewModeIconLarge"/>
                                    <MenuFlyoutItem x:Name="MainVm_Medium" Text="Medium Icons" Click="OnViewModeIconMedium"/>
                                    <MenuFlyoutItem x:Name="MainVm_Small" Text="Small Icons" Click="OnViewModeIconSmall"/>
                                </MenuFlyoutSubItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon x:Name="ViewModeIcon" Glyph="&#xF0E2;" FontSize="14"/>
                            <FontIcon Glyph="&#xE70D;" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="PreviewToggleButton" AutomationProperties.AutomationId="Button_PreviewToggle" Style="{StaticResource UnifiedButtonStyle}"
                            ToolTipService.ToolTip="미리보기 패널 (Ctrl+Shift+P)" Click="OnPreviewToggleClick"
                            Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                        <FontIcon x:Name="PreviewToggleIcon" Glyph="&#xE8A0;" FontSize="14"/>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"
                               Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}"/>
                    <Button x:Name="SplitViewButton" AutomationProperties.AutomationId="Button_SplitView" Style="{StaticResource UnifiedButtonStyle}"
                            ToolTipService.ToolTip="Split View (Ctrl+Shift+E)" Click="OnSplitViewToggleClick"
                            Visibility="{x:Bind IsNotSpecialMode(ViewModel.CurrentViewMode), Mode=OneWay}">
                        <FontIcon x:Name="SplitViewIcon" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_SplitView}" FontSize="16"/>
                    </Button>
                </StackPanel>

                <!-- ═══ RecycleBin Commands (icon-only, shown in RecycleBin mode) ═══ -->
                <StackPanel Orientation="Horizontal" Spacing="2"
                            Visibility="{x:Bind helpers:StatusBarHelper.ShowIfRecycleBin(ViewModel.CurrentViewMode), Mode=OneWay}">
                    <Button x:Name="ToolbarRestoreButton" Style="{StaticResource UnifiedButtonStyle}"
                            Click="OnRecycleBinToolbarRestoreClick" IsEnabled="False"
                            ToolTipService.ToolTip="복원 (Ctrl+Z)">
                        <FontIcon Glyph="&#xE845;" FontSize="14"/>
                    </Button>
                    <Button x:Name="ToolbarDeletePermButton" Style="{StaticResource UnifiedButtonStyle}"
                            Click="OnRecycleBinToolbarDeleteClick" IsEnabled="False"
                            ToolTipService.ToolTip="영구 삭제 (Delete)">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                    <Button x:Name="ToolbarEmptyBinButton" Style="{StaticResource UnifiedButtonStyle}"
                            Click="OnRecycleBinToolbarEmptyClick"
                            ToolTipService.ToolTip="휴지통 비우기">
                        <FontIcon Glyph="&#xE894;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                    <Button Style="{StaticResource UnifiedButtonStyle}"
                            Click="OnRecycleBinToolbarRefreshClick"
                            ToolTipService.ToolTip="새로고침 (F5)">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                </StackPanel>

                <!-- ═══ Search Box (always visible) ═══ -->
                <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                <TextBox x:Name="SearchBox" AutomationProperties.AutomationId="TextBox_Search" Width="220" Height="28" FontSize="12"
                         PlaceholderText="Search (kind: size: ext: date:)"
                         ToolTipService.ToolTip="Enter: Search current folder&#x0a;Ctrl+Enter: Search from root&#x0a;&#x0a;Advanced syntax:&#x0a;  kind:image  kind:video  kind:document&#x0a;  size:&gt;1MB  size:&lt;100KB  size:large&#x0a;  date:today  date:thisweek  date:&gt;2024-01-01&#x0a;  ext:.pdf  ext:.txt&#x0a;Combine: kind:image size:&gt;1MB"
                         KeyDown="OnSearchBoxKeyDown"/>
            </StackPanel>
        </Grid>

        <!-- 3. Main Area (column 1, row 2)
             Legacy SidebarCol/SidebarSplitterCol kept at Width=0 to suppress the old sidebar visually
             while preserving its bindings (still inside the SidebarBorder below); the new LumiSidebar
             on the left provides the visible sidebar. Stage 4 will rewire bindings to LumiSidebar
             and delete this legacy block. -->
        <Grid Grid.Column="1" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="0"/> <!-- Sidebar (legacy, hidden) -->
                <ColumnDefinition x:Name="SidebarSplitterCol" Width="0"/> <!-- Splitter (legacy, hidden) -->
                <ColumnDefinition Width="*"/>   <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar - Hybrid 3-Section Layout -->
            <!-- LEGACY sidebar — Visibility=Collapsed; bindings live until Stage 4 rewires into LumiSidebar.
                 Visibility forced collapsed so runtime SidebarCol.Width restores (200px) cannot show this. -->
            <Border x:Name="SidebarBorder" AutomationProperties.AutomationId="Sidebar" Grid.Column="0" Visibility="Collapsed" Background="{ThemeResource SpanBgLayer1Brush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              RightTapped="OnSidebarEmptyRightTapped">
                    <StackPanel Padding="0,12">

                        <!-- Section 1: 홈 -->
                        <StackPanel x:Name="SidebarHomeSection">
                        <Grid Height="28" Padding="12,0" Background="Transparent"
                              Tapped="OnHomeItemTapped"
                              PointerEntered="OnSidebarItemPointerEntered"
                              PointerExited="OnSidebarItemPointerExited">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE80F;" FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}" Foreground="{ThemeResource SpanAccentBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="SidebarHomeText" Grid.Column="1" Text="홈" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}" FontWeight="SemiBold" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>
                        </StackPanel>

                        <!-- Section 2: 즐겨찾기 (Drop Target) -->
                        <StackPanel x:Name="SidebarFavoritesSection" AllowDrop="True"
                                    DragOver="OnFavoritesDragOver"
                                    Drop="OnFavoritesDrop">
                        <TextBlock x:Name="SidebarFavoritesText" Text="즐겨찾기"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                   FontWeight="SemiBold"
                                   Margin="16,0,16,8"/>

                        <!-- Flat Favorites List (default, no tree expansion) -->
                        <ListView x:Name="FavoritesFlatList"
                                  ItemsSource="{x:Bind ViewModel.Favorites, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="OnFavoritesFlatItemClick"
                                  CanDragItems="True"
                                  CanReorderItems="True"
                                  AllowDrop="True"
                                  DragItemsCompleted="OnFavoritesDragCompleted"
                                  RightTapped="OnFavoritesFlatListRightTapped"
                                  ContainerContentChanging="OnSidebarContainerContentChanging">
                            <ListView.Resources>
                                <!-- 커스텀 Grid 호버 사용: ListViewItem 자체 hover 배경 투명화 -->
                                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent"/>
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="helpers:CursorHelper.IsHandCursor" Value="True"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:FavoriteItem">
                                    <Grid Height="26" Padding="12,0,8,0"
                                          Background="Transparent"
                                          ToolTipService.ToolTip="{x:Bind Path}"
                                          PointerEntered="OnSidebarItemPointerEntered"
                                          PointerExited="OnSidebarItemPointerExited">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind IconGlyph}"
                                                   FontFamily="{StaticResource RemixIcons}"
                                                   FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                                   Foreground="{x:Bind IconBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Name}"
                                                   FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Favorites Tree (expandable sidebar tree with lazy-loaded subfolders) -->
                        <TreeView x:Name="FavoritesTreeView"
                                  Visibility="Collapsed"
                                  SelectionMode="Single"
                                  ItemInvoked="OnFavoritesTreeItemInvoked"
                                  Expanding="OnFavoritesTreeExpanding"
                                  RightTapped="OnFavoritesTreeRightTapped"
                                  CanDragItems="False"
                                  CanReorderItems="False">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="26"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="helpers:CursorHelper.IsHandCursor" Value="True"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <DataTemplate x:DataType="TreeViewNode">
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                ToolTipService.ToolTip="{Binding Content.Path}">
                                        <TextBlock Text="{Binding Content.IconGlyph}"
                                                   FontFamily="{StaticResource RemixIcons}"
                                                   FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                                   Foreground="{Binding Content.IconBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Content.Name}"
                                                   FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                        </StackPanel>

                        <!-- ═══════ Section 3: 로컬 디스크 ═══════ -->
                        <StackPanel x:Name="SidebarLocalDrivesSection">
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>
                        <Grid Height="24" Padding="12,0" Background="Transparent"
                              Tapped="OnSidebarSectionHeaderTapped" Tag="Local"
                              PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE70D;" FontSize="10" Margin="0,0,6,0"
                                      VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5">
                                <FontIcon.RenderTransform>
                                    <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsLocalDrivesExpanded), Mode=OneWay}"/>
                                </FontIcon.RenderTransform>
                            </FontIcon>
                            <TextBlock x:Name="SidebarLocalDrivesText" Grid.Column="1" Text="로컬 디스크"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SpanTextTertiaryBrush}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsLocalDrivesExpanded, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DriveItem">
                                    <Grid Height="26" Padding="12,0,8,0" Background="Transparent"
                                          ToolTipService.ToolTip="{x:Bind TooltipText}"
                                          Tapped="OnDriveItemTapped" RightTapped="OnSidebarDriveRightTapped"
                                          PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind IconGlyph}"
                                                   FontFamily="{StaticResource RemixIcons}" FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        </StackPanel>

                        <!-- ═══════ Section 4: 클라우드 (CloudDrives 있을 때만) ═══════ -->
                        <StackPanel x:Name="SidebarCloudSection" Visibility="{x:Bind ViewModel.HasCloudDrives, Mode=OneWay}">
                            <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>
                            <Grid Height="24" Padding="12,0" Background="Transparent"
                                  Tapped="OnSidebarSectionHeaderTapped" Tag="Cloud"
                                  PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE70D;" FontSize="10" Margin="0,0,6,0"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsCloudDrivesExpanded), Mode=OneWay}"/>
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                                <TextBlock x:Name="SidebarCloudText" Grid.Column="1" Text="클라우드"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SpanTextTertiaryBrush}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CloudDrives, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.IsCloudDrivesExpanded, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveItem">
                                        <Grid Height="26" Padding="12,0,8,0" Background="Transparent"
                                              ToolTipService.ToolTip="{x:Bind TooltipText}"
                                              Tapped="OnDriveItemTapped" RightTapped="OnSidebarDriveRightTapped"
                                              PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind IconGlyph}"
                                                       FontFamily="{StaticResource RemixIcons}" FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                                       Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ═══════ Section 5: 네트워크 (NetworkAndRemoteDrives 있을 때만) ═══════ -->
                        <StackPanel x:Name="SidebarNetworkSection" Visibility="{x:Bind ViewModel.HasNetworkDrives, Mode=OneWay}">
                            <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>
                            <Grid Height="24" Padding="12,0" Background="Transparent"
                                  Tapped="OnSidebarSectionHeaderTapped" Tag="Network"
                                  PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE70D;" FontSize="10" Margin="0,0,6,0"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsNetworkDrivesExpanded), Mode=OneWay}"/>
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                                <TextBlock x:Name="SidebarNetworkText" Grid.Column="1" Text="네트워크"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SpanTextTertiaryBrush}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.NetworkAndRemoteDrives, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.IsNetworkDrivesExpanded, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveItem">
                                        <Grid Height="26" Padding="12,0,8,0" Background="Transparent"
                                              ToolTipService.ToolTip="{x:Bind TooltipText}"
                                              Tapped="OnDriveItemTapped" RightTapped="OnSidebarDriveRightTapped"
                                              PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Width="16" Height="16"
                                                  VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="{x:Bind IconGlyph}"
                                                           FontFamily="{StaticResource RemixIcons}" FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- 잠금 뱃지: 인증 필요 시 표시 -->
                                                <FontIcon Glyph="&#xE72E;" FontSize="7"
                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                          HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                          Margin="0,0,-4,-4"
                                                          Visibility="{x:Bind AuthBadgeVisibility}"/>
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ═══════ Section 6: 휴지통 ═══════ -->
                        <StackPanel x:Name="SidebarRecycleBinSection">
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>

                        <Grid Height="36" Padding="12,0" Background="Transparent"
                              Tapped="OnRecycleBinTapped"
                              AllowDrop="True"
                              DragOver="OnRecycleBinDragOver"
                              Drop="OnRecycleBinDrop"
                              PointerEntered="OnSidebarItemPointerEntered"
                              PointerExited="OnSidebarItemPointerExited"
                              AutomationProperties.AutomationId="Sidebar_RecycleBin">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 아이콘 (비어있음/참 전환) -->
                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind ViewModel.RecycleBinIconGlyph, Mode=OneWay}"
                                       FontFamily="{StaticResource RemixIcons}" FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                       Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <!-- 라벨 -->
                            <TextBlock Grid.Column="1"
                                       x:Name="RecycleBinLabel"
                                       Text="Recycle Bin" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                       VerticalAlignment="Center"/>

                            <!-- 항목 개수 배지 -->
                            <Border Grid.Column="2"
                                    Visibility="{x:Bind helpers:ConverterHelpers.NotBoolToVisibility(ViewModel.RecycleBinIsEmpty), Mode=OneWay}"
                                    Background="{ThemeResource SpanBgHoverBrush}"
                                    CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.RecycleBinItemCount, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                            </Border>
                        </Grid>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Sidebar bottom bar: Help, Log (left) | Settings (right) -->
                <Grid Grid.Row="1"
                      BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0"
                      Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="0" HorizontalAlignment="Left">
                        <Button x:Name="HelpButton" AutomationProperties.AutomationId="Button_Help" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="단축키 도움말 (Shift+?)" Click="OnHelpClick"
                                Padding="6,4" MinWidth="0" MinHeight="0">
                            <FontIcon Glyph="&#xE897;" FontSize="14"/>
                        </Button>
                        <Button x:Name="LogButton" AutomationProperties.AutomationId="Button_Log" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="작업 로그" Click="OnLogClick"
                                Padding="6,4" MinWidth="0" MinHeight="0">
                            <FontIcon Glyph="&#xE81C;" FontSize="14"/>
                        </Button>
                        <Button x:Name="WorkspaceButton" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="워크스페이스"
                                Padding="6,4" MinWidth="0" MinHeight="0"
                                helpers:CursorHelper.IsHandCursor="True">
                            <FontIcon Glyph="&#xE737;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                    <Button x:Name="SettingsButton" AutomationProperties.AutomationId="Button_Settings" Style="{StaticResource UnifiedButtonStyle}"
                            ToolTipService.ToolTip="설정" Click="OnSettingsClick"
                            Padding="6,4" MinWidth="0" MinHeight="0"
                            HorizontalAlignment="Right">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                    </Button>
                </Grid>
                </Grid>
            </Border>

            <!-- Sidebar Resize Splitter — LEGACY collapsed (no longer needed; LumiSidebar has fixed width). -->
            <Border x:Name="SidebarSplitter" Grid.Column="1" Width="6" Visibility="Collapsed"
                    Background="{ThemeResource SpanBgLayer1Brush}"
                    BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,1,0"
                    ManipulationMode="TranslateX" ManipulationStarted="OnSidebarSplitterManipulationStarted"
                    ManipulationDelta="OnSidebarSplitterManipulationDelta"
                    PointerEntered="OnSidebarSplitterPointerEntered" PointerExited="OnSidebarSplitterPointerExited"/>


            <!-- Content (Split View Container) -->
            <Grid Grid.Column="2" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="SplitterCol" Width="0"/>
                    <ColumnDefinition x:Name="RightPaneCol" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT PANE ===== -->
                <Grid x:Name="LeftPaneContainer" AutomationProperties.AutomationId="LeftPane" Grid.Column="0" GotFocus="OnLeftPaneGotFocus"
                      Background="Transparent"
                      AllowDrop="True" DragOver="OnPaneDragOver" Drop="OnPaneDrop" DragLeave="OnPaneDragLeave">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/> <!-- FilterBar -->
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/> <!-- Git Status Bar -->
                        <RowDefinition Height="Auto"/> <!-- Path Bar (split mode only) -->
                    </Grid.RowDefinitions>

                    <!-- Drop overlay (cross-pane visual feedback) -->
                    <Border x:Name="LeftDropOverlay" Grid.RowSpan="5" Opacity="0" IsHitTestVisible="False"
                            Background="{ThemeResource SpanAccentBrush}" CornerRadius="4" Margin="4"/>

                    <!-- Left Pane Path Header (split mode, hidden in Home).
                         Span jank tones (SpanBgLayer2Brush, SpanBorderSubtle, top accent line)
                         removed in favor of LumiFiles transparent floating treatment. The
                         segmented pill controls inside (Phase 3) carry their own visible fills,
                         and the active pane indicator now lives on the toolbar tone + folder
                         label (A+D combo) rather than a 1px accent strip. -->
                    <!-- Stage S-2: per-pane mini toolbar removed. Single LumiToolbar at the
                         top of the window now handles all actions, binding to ActiveExplorer
                         so it follows whichever pane has focus. The 32px header keeps just
                         the active-pane indicator (PillBrush bg + amber folder label) so
                         users can tell at a glance which pane is the action target. -->
                    <Grid Grid.Row="0" x:Name="LeftPathHeader" Height="32"
                          Visibility="{x:Bind IsLeftPaneHeaderVisible(ViewModel.IsSplitViewEnabled, ViewModel.CurrentViewMode), Mode=OneWay}"
                          Background="{x:Bind LeftPaneActiveBrush(ViewModel.ActivePane), Mode=OneWay}"
                          Tapped="OnLeftPaneHeaderTapped">
                        <StackPanel Orientation="Horizontal" Spacing="7"
                                    VerticalAlignment="Center" Padding="14,0,14,0">
                            <FontIcon Glyph="&#xE8B7;" FontSize="14" Foreground="{ThemeResource LumiAmberBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.Explorer.CurrentFolderName, Mode=OneWay}"
                                       FontFamily="{StaticResource LumiFontFamily}"
                                       FontSize="{StaticResource LumiFontSizeBase}"
                                       FontWeight="Medium"
                                       Foreground="{x:Bind LeftPaneActiveLabelBrush(ViewModel.ActivePane), Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>

                    <!-- Filter Bar (Ctrl+Shift+F) -->
                    <Grid x:Name="LeftFilterBar" Grid.Row="1" Height="32" Visibility="Collapsed"
                          Background="{ThemeResource SpanBgLayer2Brush}"
                          BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Filter icon -->
                            <ColumnDefinition Width="*"/>     <!-- TextBox -->
                            <ColumnDefinition Width="Auto"/>  <!-- Count -->
                            <ColumnDefinition Width="Auto"/>  <!-- Close button -->
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE71C;" FontSize="12" Margin="10,0,6,0"
                                  Foreground="{ThemeResource SpanTextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="LeftFilterTextBox" Grid.Column="1"
                                 PlaceholderText="&#xD544;&#xD130;... (*.txt, keyword)"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="12" VerticalAlignment="Center"
                                 TextChanged="OnFilterTextChanged"
                                 KeyDown="OnFilterTextBoxKeyDown"/>
                        <TextBlock x:Name="LeftFilterCountText" Grid.Column="2"
                                   FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="4,0"/>
                        <Button Grid.Column="3" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="&#xD544;&#xD130; &#xB2EB;&#xAE30; (Esc)"
                                Click="OnFilterBarClose"
                                Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26"
                                Margin="0,0,4,0" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE711;" FontSize="10"/>
                        </Button>
                    </Grid>

                    <!-- Left Pane Content -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition x:Name="LeftPreviewSplitterCol" Width="0"/>
                            <ColumnDefinition x:Name="LeftPreviewCol" Width="0"/>
                        </Grid.ColumnDefinitions>

                        <!-- Explorer Views -->
                        <Grid Grid.Column="0">
                            <!-- Miller Columns Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="MillerTabsHost" AutomationProperties.AutomationId="Host_Miller">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 첫 번째 탭 전용 (XAML 정의) — 추가 탭은 코드에서 동적 생성 -->
                                <ScrollViewer x:Name="MillerScrollViewer" Grid.Column="0"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              VerticalScrollMode="Disabled"
                                              AllowDrop="True"
                                              DragOver="OnMillerEmptyAreaDragOver"
                                              DragLeave="OnMillerEmptyAreaDragLeave"
                                              >
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <ItemsControl x:Name="MillerColumnsControl" HorizontalAlignment="Left">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                            <Grid Width="{Binding MillerColumnWidth, Source={StaticResource FontScale}}" MinWidth="150">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        BorderBrush="{ThemeResource LumiDividerSoftBrush}"
                                                        BorderThickness="0,0,1,0"
                                                        Background="Transparent">
                                                    <Grid Loaded="OnMillerColumnContentGridLoaded" Unloaded="OnMillerColumnContentGridUnloaded"
                                                          PointerPressed="OnMillerColumnPointerPressed">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <!-- LumiFiles col-header (mockup): folder name + child count -->
                                                            <Grid Grid.Row="0" Padding="14,8,14,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid Grid.Column="0">
                                                                    <!-- Active column: amber accent on the folder name -->
                                                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                                               FontFamily="{StaticResource LumiFontFamily}"
                                                                               FontSize="{StaticResource LumiFontSizeColHeader}"
                                                                               FontWeight="Medium"
                                                                               Foreground="{ThemeResource LumiAmberBrush}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Visibility="{x:Bind IsActiveColumnVisible, Mode=OneWay}"/>
                                                                    <!-- Inactive column: standard tertiary tone -->
                                                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                                               FontFamily="{StaticResource LumiFontFamily}"
                                                                               FontSize="{StaticResource LumiFontSizeColHeader}"
                                                                               FontWeight="Medium"
                                                                               Foreground="{ThemeResource LumiTextTertiaryBrush}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Visibility="{x:Bind IsInactiveColumnVisible, Mode=OneWay}"/>
                                                                </Grid>
                                                                <TextBlock Grid.Column="1" Text="{x:Bind TotalChildCount, Mode=OneWay}"
                                                                           FontFamily="{StaticResource LumiFontFamily}"
                                                                           FontSize="{StaticResource LumiFontSizeColHeader}"
                                                                           Foreground="{ThemeResource LumiTextTertiaryBrush}"
                                                                           Opacity="0.7"/>
                                                            </Grid>
                                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Children, Mode=OneWay}" SelectedItem="{x:Bind SelectedChild, Mode=OneWay}"
                                                                      SelectionMode="Extended" IsItemClickEnabled="False"
                                                                      CanDragItems="True" AllowDrop="True"
                                                                      Background="Transparent"
                                                                      ItemContainerStyle="{StaticResource MillerColumnItemStyle}"
                                                                      DragItemsStarting="OnDragItemsStarting" DragItemsCompleted="OnDragItemsCompleted"
                                                                      DragOver="OnColumnDragOver" Drop="OnColumnDrop"
                                                                      GotFocus="OnMillerColumnGotFocus"
                                                                      SelectionChanged="OnMillerColumnSelectionChanged"
                                                                      DoubleTapped="OnMillerColumnDoubleTapped"
                                                                      RightTapped="OnMillerColumnEmptyAreaRightTapped"
                                                                      ContainerContentChanging="OnMillerContainerContentChanging">
                                                                <ListView.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <ItemsStackPanel CacheLength="1.0"/>
                                                                    </ItemsPanelTemplate>
                                                                </ListView.ItemsPanel>
                                                                <ListView.ItemContainerTransitions>
                                                                    <TransitionCollection/>
                                                                </ListView.ItemContainerTransitions>
                                                                <ListView.ItemTemplateSelector>
                                                                    <local:FileSystemItemTemplateSelector>
                                                                        <local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                                                                <Grid Padding="10,4" MinHeight="26" RightTapped="OnFolderRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Opacity="{x:Bind ItemOpacity, Mode=OneWay}"
                                                                                      AllowDrop="True" DragOver="OnFolderItemDragOver" Drop="OnFolderItemDrop" DragLeave="OnFolderItemDragLeave">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <!-- Col0: reserved for layout alignment (indicator handled by floating overlay) -->
                                                                                    <Grid Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                                        <Image Source="{x:Bind CustomIcon, Mode=OneWay}" Stretch="Uniform"
                                                                                               Width="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                                                                               Height="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                                                                               Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasCustomIcon), Mode=OneWay}"
                                                                                               IsHitTestVisible="False"/>
                                                                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Folder}" FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}" Foreground="{x:Bind IconBrush}"
                                                                                                  Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfFalse(HasCustomIcon), Mode=OneWay}"
                                                                                                  IsHitTestVisible="False"/>
                                                                                    </Grid>
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="2" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                    <!-- Item count badge -->
                                                                                    <TextBlock Grid.Column="3" Text="{x:Bind ChildCountText, Mode=OneWay}" VerticalAlignment="Center"
                                                                                               FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Margin="4,0,4,0"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <FontIcon Grid.Column="4" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_ChevronRight}" FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.5"
                                                                                             Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(HasChildren), Mode=OneWay}"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                        <local:FileSystemItemTemplateSelector.FileTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FileViewModel">
                                                                                <Grid Padding="10,4" MinHeight="26" RightTapped="OnFileRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Opacity="{x:Bind ItemOpacity, Mode=OneWay}">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <!-- Col0: path indicator placeholder (matches FolderTemplate column structure) -->
                                                                                    <Border Grid.Column="0" Width="1" CornerRadius="0.5" Margin="-8,2,0,2" Visibility="Collapsed"/>
                                                                                    <Grid Grid.Column="1" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                                        <!-- Opacity 전환: Visibility→Opacity로 레이아웃 패스 없이 렌더링만 전환 (14K 스크롤 지터 방지) -->
                                                                                        <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                                                                                               Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasThumbnail), Mode=OneWay}"
                                                                                               IsHitTestVisible="False" x:Phase="1"/>
                                                                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{x:Bind IconGlyph}" FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}" Foreground="{x:Bind IconBrush}"
                                                                                                  Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfFalse(HasThumbnail), Mode=OneWay}"
                                                                                                  IsHitTestVisible="False"/>
                                                                                        <Border Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasCloudBadge), Mode=OneWay}"
                                                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                                                                Width="12" Height="12" CornerRadius="6"
                                                                                                Background="{x:Bind CloudBadgeBrush, Mode=OneWay}"
                                                                                                IsHitTestVisible="False" x:Phase="1">
                                                                                            <FontIcon Glyph="{x:Bind CloudStateGlyph, Mode=OneWay}" FontSize="8"
                                                                                                      Foreground="{ThemeResource SpanTextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <!-- Git 뱃지 (동일 위치, Git 우선 — 위에 렌더링) -->
                                                                                        <Border Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasGitBadge), Mode=OneWay}"
                                                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                                                                Width="14" Height="14" CornerRadius="7"
                                                                                                Background="{x:Bind GitStatusBrush, Mode=OneWay}"
                                                                                                IsHitTestVisible="False" x:Phase="1">
                                                                                            <TextBlock Text="{x:Bind GitStatusText, Mode=OneWay}" FontSize="8" FontWeight="Bold"
                                                                                                       Foreground="{x:Bind GitBadgeTextBrush, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                       Margin="0,-1,0,0"/>
                                                                                        </Border>
                                                                                    </Grid>
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="2" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FileTemplate>
                                                                    </local:FileSystemItemTemplateSelector>
                                                                </ListView.ItemTemplateSelector>
                                                            </ListView>
                                                            <!-- Loading indicator — visible while folder contents load -->
                                                            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}"
                                                                          Width="20" Height="20"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <!-- Empty folder message -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(IsEmpty), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="4" Opacity="0.5">
                                                                <FontIcon Glyph="&#xE8B7;" FontSize="24"
                                                                          Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind viewmodels:FolderViewModel.GetEmptyFolderText()}" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                            <!-- Error state -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(HasError), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="8" Opacity="0.7">
                                                                <FontIcon Glyph="{x:Bind ErrorIcon, Mode=OneWay}" FontSize="28"
                                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind ErrorMessage, Mode=OneWay}" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                                           TextWrapping="Wrap" MaxWidth="200" TextAlignment="Center"
                                                                           HorizontalAlignment="Center"/>
                                                                <HyperlinkButton Content="{x:Bind viewmodels:FolderViewModel.GetRetryText()}" FontSize="11"
                                                                                 HorizontalAlignment="Center"
                                                                                 Click="OnRetryFolderLoad" Tag="{x:Bind}" />
                                                            </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <!-- Column edge shadow (depth) -->
                                                <Rectangle Grid.Column="1" Width="8" HorizontalAlignment="Left" Margin="-7,0,0,0"
                                                           Fill="{ThemeResource SpanColumnShadowBrush}" IsHitTestVisible="False"/>
                                                <!-- Column resize grip -->
                                                <Rectangle Grid.Column="1" Width="4" Fill="Transparent"
                                                           PointerEntered="OnColumnResizeGripPointerEntered"
                                                           PointerExited="OnColumnResizeGripPointerExited"
                                                           PointerPressed="OnColumnResizeGripPointerPressed"
                                                           PointerMoved="OnColumnResizeGripPointerMoved"
                                                           PointerReleased="OnColumnResizeGripPointerReleased"
                                                           DoubleTapped="OnColumnResizeGripDoubleTapped"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>

                            </Grid>

                            <!-- Details View Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="DetailsTabsHost" AutomationProperties.AutomationId="Host_Details" Visibility="Collapsed">
                                <views:DetailsModeView x:Name="DetailsView"/>
                            </Grid>

                            <!-- List View Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="ListTabsHost" AutomationProperties.AutomationId="Host_List" Visibility="Collapsed">
                                <views:ListModeView x:Name="ListView"/>
                            </Grid>

                            <!-- Icon View Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="IconTabsHost" AutomationProperties.AutomationId="Host_Icon" Visibility="Collapsed">
                                <views:IconModeView x:Name="IconView"/>
                            </Grid>

                            <!-- Home View (Left only) -->
                            <views:HomeModeView x:Name="HomeView"
                                                Visibility="Collapsed"/>

                            <!-- Settings View (Left only) -->
                            <views:SettingsModeView x:Name="SettingsView"
                                                    Visibility="Collapsed"/>

                            <!-- Action Log View (Left only) -->
                            <views:LogModeView x:Name="LogView"
                                               Visibility="Collapsed"/>

                            <!-- Recycle Bin View (Left only) -->
                            <views:RecycleBinModeView x:Name="RecycleBinView"
                                                      Visibility="Collapsed"/>
                        </Grid>

                        <!-- Preview Splitter (Left) -->
                        <controls:GridSplitter Grid.Column="1" Width="2"
                            Background="Transparent"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsLeftPreviewEnabled), Mode=OneWay}"/>

                        <!-- Preview Panel (Left) -->
                        <views:PreviewPanelView x:Name="LeftPreviewPanel" Grid.Column="2"
                            MinWidth="320"
                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1,0,0,0"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsLeftPreviewEnabled), Mode=OneWay}"/>
                    </Grid>

                    <!-- Git Status Bar (Left) -->
                    <Border x:Name="LeftGitStatusBar" Grid.Row="3" Grid.ColumnSpan="3"
                            Height="28" Background="{ThemeResource SpanBgLayer2Brush}"
                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0"
                            Visibility="Collapsed">
                        <Button x:Name="LeftGitStatusButton"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="12,0" Height="28">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8AD;" FontSize="12"
                                          Foreground="{ThemeResource SpanAccentBrush}"/>
                                <TextBlock x:Name="LeftGitBranch" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Rectangle Width="1" Height="14" Fill="{ThemeResource SpanBorderSubtleBrush}"
                                           Margin="4,0"/>
                                <TextBlock x:Name="LeftGitStatus" FontSize="12" Opacity="0.8"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="TopEdgeAlignedRight">
                                    <StackPanel Width="320" Spacing="12" Padding="4">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8AD;" FontSize="14"
                                                          Foreground="{ThemeResource SpanAccentBrush}"/>
                                                <TextBlock x:Name="LeftFlyoutBranch" FontSize="14"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <TextBlock x:Name="LeftFlyoutStatus" FontSize="12" Opacity="0.8"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="LeftFlyoutCommitsLabel" FontSize="11"
                                                       FontWeight="SemiBold" Opacity="0.6"/>
                                            <TextBlock x:Name="LeftFlyoutCommits"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="LeftFlyoutFilesLabel" FontSize="11"
                                                       FontWeight="SemiBold" Opacity="0.6"/>
                                            <ScrollViewer MaxHeight="200">
                                                <TextBlock x:Name="LeftFlyoutFiles"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="11"/>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Border>

                    <!-- Left Pane Path Bar — split mode only. Sits at the bottom row of the
                         pane container itself so the breadcrumb aligns with this pane's actual
                         column area (vs the legacy outer status bar which spanned the whole
                         content+sidebar grid). Single mode keeps the outer LumiPathBar. -->
                    <appcontrols:LumiPanePathBar Grid.Row="4" Grid.ColumnSpan="3"
                                                 x:Name="LeftPanePathBar"
                                                 Mode="Left"
                                                 Height="{StaticResource LumiPathBarHeight}"
                                                 PathSegments="{x:Bind ViewModel.Explorer.PathSegments, Mode=OneWay}"
                                                 Visibility="{x:Bind helpers:ConverterHelpers.BoolToVisibility(ViewModel.IsSplitViewEnabled), Mode=OneWay}"/>
                </Grid>

                <!-- ===== RIGHT PANE ===== -->
                <Grid x:Name="RightPaneContainer" AutomationProperties.AutomationId="RightPane" Grid.Column="2" GotFocus="OnRightPaneGotFocus"
                      Background="Transparent" Margin="1,0,0,0"
                      AllowDrop="True" DragOver="OnPaneDragOver" Drop="OnPaneDrop" DragLeave="OnPaneDragLeave"
                      Visibility="{x:Bind IsSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/> <!-- Git Status Bar -->
                        <RowDefinition Height="Auto"/> <!-- Path Bar (split mode only) -->
                    </Grid.RowDefinitions>

                    <!-- Drop overlay (cross-pane visual feedback) -->
                    <Border x:Name="RightDropOverlay" Grid.RowSpan="4" Opacity="0" IsHitTestVisible="False"
                            Background="{ThemeResource SpanAccentBrush}" CornerRadius="4" Margin="4"/>

                    <!-- Right Pane Path Header — same Stage S-2 simplification as LeftPathHeader.
                         All nav / address / action / sort / view-mode / preview controls
                         removed; only the active-pane indicator (PillBrush bg + amber folder
                         label) remains. The single LumiToolbar at the top handles every
                         action via ActiveExplorer binding. -->
                    <Grid Grid.Row="0" x:Name="RightPathHeader" Height="32"
                          Background="{x:Bind RightPaneActiveBrush(ViewModel.ActivePane), Mode=OneWay}"
                          Tapped="OnRightPaneHeaderTapped">
                        <StackPanel Orientation="Horizontal" Spacing="7"
                                    VerticalAlignment="Center" Padding="14,0,14,0">
                            <FontIcon Glyph="&#xE8B7;" FontSize="14" Foreground="{ThemeResource LumiAmberBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.RightExplorer.CurrentFolderName, Mode=OneWay}"
                                       FontFamily="{StaticResource LumiFontFamily}"
                                       FontSize="{StaticResource LumiFontSizeBase}"
                                       FontWeight="Medium"
                                       Foreground="{x:Bind RightPaneActiveLabelBrush(ViewModel.ActivePane), Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>

                    <!-- Right Pane Content -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition x:Name="RightPreviewSplitterCol" Width="0"/>
                            <ColumnDefinition x:Name="RightPreviewCol" Width="0"/>
                        </Grid.ColumnDefinitions>

                        <!-- Explorer Views -->
                        <Grid Grid.Column="0">
                            <!-- Miller Columns View (Right) -->
                            <ScrollViewer x:Name="MillerScrollViewerRight"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Visibility="{x:Bind IsMillerColumnsMode(ViewModel.RightViewMode), Mode=OneWay}"
                                          AllowDrop="True"
                                          DragOver="OnMillerEmptyAreaDragOver"
                                          DragLeave="OnMillerEmptyAreaDragLeave">
                                <ItemsControl x:Name="MillerColumnsControlRight" ItemsSource="{x:Bind ViewModel.RightExplorer.Columns, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                            <Grid Width="{Binding MillerColumnWidth, Source={StaticResource FontScale}}" MinWidth="150">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        BorderBrush="{ThemeResource LumiDividerSoftBrush}"
                                                        BorderThickness="0,0,1,0"
                                                        Background="Transparent">
                                                    <Grid Loaded="OnMillerColumnContentGridLoaded" Unloaded="OnMillerColumnContentGridUnloaded"
                                                          PointerPressed="OnMillerColumnPointerPressed">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <!-- LumiFiles col-header (mockup): folder name + child count -->
                                                            <Grid Grid.Row="0" Padding="14,8,14,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid Grid.Column="0">
                                                                    <!-- Active column: amber accent on the folder name -->
                                                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                                               FontFamily="{StaticResource LumiFontFamily}"
                                                                               FontSize="{StaticResource LumiFontSizeColHeader}"
                                                                               FontWeight="Medium"
                                                                               Foreground="{ThemeResource LumiAmberBrush}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Visibility="{x:Bind IsActiveColumnVisible, Mode=OneWay}"/>
                                                                    <!-- Inactive column: standard tertiary tone -->
                                                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                                               FontFamily="{StaticResource LumiFontFamily}"
                                                                               FontSize="{StaticResource LumiFontSizeColHeader}"
                                                                               FontWeight="Medium"
                                                                               Foreground="{ThemeResource LumiTextTertiaryBrush}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Visibility="{x:Bind IsInactiveColumnVisible, Mode=OneWay}"/>
                                                                </Grid>
                                                                <TextBlock Grid.Column="1" Text="{x:Bind TotalChildCount, Mode=OneWay}"
                                                                           FontFamily="{StaticResource LumiFontFamily}"
                                                                           FontSize="{StaticResource LumiFontSizeColHeader}"
                                                                           Foreground="{ThemeResource LumiTextTertiaryBrush}"
                                                                           Opacity="0.7"/>
                                                            </Grid>
                                                            <ListView Grid.Row="1" ItemsSource="{x:Bind Children, Mode=OneWay}" SelectedItem="{x:Bind SelectedChild, Mode=OneWay}"
                                                                      SelectionMode="Extended" IsItemClickEnabled="False"
                                                                      CanDragItems="True" AllowDrop="True"
                                                                      Background="Transparent"
                                                                      ItemContainerStyle="{StaticResource MillerColumnItemStyle}"
                                                                      DragItemsStarting="OnDragItemsStarting" DragItemsCompleted="OnDragItemsCompleted"
                                                                      DragOver="OnColumnDragOver" Drop="OnColumnDrop"
                                                                      GotFocus="OnMillerColumnGotFocus"
                                                                      SelectionChanged="OnMillerColumnSelectionChanged"
                                                                      DoubleTapped="OnMillerColumnDoubleTapped"
                                                                      RightTapped="OnMillerColumnEmptyAreaRightTapped"
                                                                      ContainerContentChanging="OnMillerContainerContentChanging">
                                                                <ListView.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <ItemsStackPanel CacheLength="1.0"/>
                                                                    </ItemsPanelTemplate>
                                                                </ListView.ItemsPanel>
                                                                <ListView.ItemContainerTransitions>
                                                                    <TransitionCollection/>
                                                                </ListView.ItemContainerTransitions>
                                                                <ListView.ItemTemplateSelector>
                                                                    <local:FileSystemItemTemplateSelector>
                                                                        <local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                                                                <Grid Padding="10,4" MinHeight="26" RightTapped="OnFolderRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Opacity="{x:Bind ItemOpacity, Mode=OneWay}"
                                                                                      AllowDrop="True" DragOver="OnFolderItemDragOver" Drop="OnFolderItemDrop" DragLeave="OnFolderItemDragLeave">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <!-- Col0: reserved for layout alignment (indicator handled by floating overlay) -->
                                                                                    <Grid Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                                        <Image Source="{x:Bind CustomIcon, Mode=OneWay}" Stretch="Uniform"
                                                                                               Width="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                                                                               Height="{Binding IconFontSize, Source={StaticResource FontScale}}"
                                                                                               Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasCustomIcon), Mode=OneWay}"
                                                                                               IsHitTestVisible="False"/>
                                                                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Folder}" FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}" Foreground="{x:Bind IconBrush}"
                                                                                                  Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfFalse(HasCustomIcon), Mode=OneWay}"
                                                                                                  IsHitTestVisible="False"/>
                                                                                    </Grid>
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="2" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                    <!-- Item count badge -->
                                                                                    <TextBlock Grid.Column="3" Text="{x:Bind ChildCountText, Mode=OneWay}" VerticalAlignment="Center"
                                                                                               FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Margin="4,0,4,0"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <FontIcon Grid.Column="4" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_ChevronRight}" FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.5"
                                                                                             Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(HasChildren), Mode=OneWay}"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                        <local:FileSystemItemTemplateSelector.FileTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FileViewModel">
                                                                                <Grid Padding="10,4" MinHeight="26" RightTapped="OnFileRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Opacity="{x:Bind ItemOpacity, Mode=OneWay}">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <!-- Col0: path indicator placeholder (matches FolderTemplate column structure) -->
                                                                                    <Border Grid.Column="0" Width="1" CornerRadius="0.5" Margin="-8,2,0,2" Visibility="Collapsed"/>
                                                                                    <Grid Grid.Column="1" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                                        <!-- Opacity 전환: Visibility→Opacity로 레이아웃 패스 없이 렌더링만 전환 (14K 스크롤 지터 방지) -->
                                                                                        <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                                                                                               Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasThumbnail), Mode=OneWay}"
                                                                                               IsHitTestVisible="False" x:Phase="1"/>
                                                                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{x:Bind IconGlyph}" FontSize="{Binding IconFontSize, Source={StaticResource FontScale}}" Foreground="{x:Bind IconBrush}"
                                                                                                  Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfFalse(HasThumbnail), Mode=OneWay}"
                                                                                                  IsHitTestVisible="False"/>
                                                                                        <Border Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasCloudBadge), Mode=OneWay}"
                                                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                                                                Width="12" Height="12" CornerRadius="6"
                                                                                                Background="{x:Bind CloudBadgeBrush, Mode=OneWay}"
                                                                                                IsHitTestVisible="False" x:Phase="1">
                                                                                            <FontIcon Glyph="{x:Bind CloudStateGlyph, Mode=OneWay}" FontSize="8"
                                                                                                      Foreground="{ThemeResource SpanTextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <!-- Git 뱃지 (동일 위치, Git 우선 — 위에 렌더링) -->
                                                                                        <Border Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasGitBadge), Mode=OneWay}"
                                                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                                                                Width="14" Height="14" CornerRadius="7"
                                                                                                Background="{x:Bind GitStatusBrush, Mode=OneWay}"
                                                                                                IsHitTestVisible="False" x:Phase="1">
                                                                                            <TextBlock Text="{x:Bind GitStatusText, Mode=OneWay}" FontSize="8" FontWeight="Bold"
                                                                                                       Foreground="{x:Bind GitBadgeTextBrush, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                       Margin="0,-1,0,0"/>
                                                                                        </Border>
                                                                                    </Grid>
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="2" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="{Binding ItemFontSize, Source={StaticResource FontScale}}"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FileTemplate>
                                                                    </local:FileSystemItemTemplateSelector>
                                                                </ListView.ItemTemplateSelector>
                                                            </ListView>
                                                            <!-- Loading indicator — visible while folder contents load -->
                                                            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}"
                                                                          Width="20" Height="20"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <!-- Empty folder message -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(IsEmpty), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="4" Opacity="0.5">
                                                                <FontIcon Glyph="&#xE8B7;" FontSize="24"
                                                                          Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind viewmodels:FolderViewModel.GetEmptyFolderText()}" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                            <!-- Error state -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(HasError), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="8" Opacity="0.7">
                                                                <FontIcon Glyph="{x:Bind ErrorIcon, Mode=OneWay}" FontSize="28"
                                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind ErrorMessage, Mode=OneWay}" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                                           TextWrapping="Wrap" MaxWidth="200" TextAlignment="Center"
                                                                           HorizontalAlignment="Center"/>
                                                                <HyperlinkButton Content="{x:Bind viewmodels:FolderViewModel.GetRetryText()}" FontSize="11"
                                                                                 HorizontalAlignment="Center"
                                                                                 Click="OnRetryFolderLoad" Tag="{x:Bind}" />
                                                            </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <!-- Column edge shadow (depth) -->
                                                <Rectangle Grid.Column="1" Width="8" HorizontalAlignment="Left" Margin="-7,0,0,0"
                                                           Fill="{ThemeResource SpanColumnShadowBrush}" IsHitTestVisible="False"/>
                                                <!-- Column resize grip -->
                                                <Rectangle Grid.Column="1" Width="4" Fill="Transparent"
                                                           PointerEntered="OnColumnResizeGripPointerEntered"
                                                           PointerExited="OnColumnResizeGripPointerExited"
                                                           PointerPressed="OnColumnResizeGripPointerPressed"
                                                           PointerMoved="OnColumnResizeGripPointerMoved"
                                                           PointerReleased="OnColumnResizeGripPointerReleased"
                                                           DoubleTapped="OnColumnResizeGripDoubleTapped"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Home View (Right) -->
                            <views:HomeModeView x:Name="HomeViewRight"
                                                Visibility="{x:Bind IsHomeMode(ViewModel.RightViewMode), Mode=OneWay}"/>

                            <!-- Details View (Right) -->
                            <views:DetailsModeView x:Name="DetailsViewRight"
                                                   Visibility="{x:Bind IsDetailsMode(ViewModel.RightViewMode), Mode=OneWay}"/>

                            <!-- List View (Right) -->
                            <views:ListModeView x:Name="ListViewRight"
                                                Visibility="{x:Bind IsListMode(ViewModel.RightViewMode), Mode=OneWay}"/>

                            <!-- Icon View (Right) -->
                            <views:IconModeView x:Name="IconViewRight"
                                                Visibility="{x:Bind IsIconMode(ViewModel.RightViewMode), Mode=OneWay}"/>
                        </Grid>

                        <!-- Preview Splitter (Right) -->
                        <controls:GridSplitter Grid.Column="1" Width="2"
                            Background="Transparent"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsRightPreviewEnabled), Mode=OneWay}"/>

                        <!-- Preview Panel (Right) -->
                        <views:PreviewPanelView x:Name="RightPreviewPanel" Grid.Column="2"
                            MinWidth="320"
                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1,0,0,0"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsRightPreviewEnabled), Mode=OneWay}"/>
                    </Grid>

                    <!-- Git Status Bar (Right) -->
                    <Border x:Name="RightGitStatusBar" Grid.Row="2" Grid.ColumnSpan="3"
                            Height="28" Background="{ThemeResource SpanBgLayer2Brush}"
                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0"
                            Visibility="Collapsed">
                        <Button x:Name="RightGitStatusButton"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="12,0" Height="28">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8AD;" FontSize="12"
                                          Foreground="{ThemeResource SpanAccentBrush}"/>
                                <TextBlock x:Name="RightGitBranch" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Rectangle Width="1" Height="14" Fill="{ThemeResource SpanBorderSubtleBrush}"
                                           Margin="4,0"/>
                                <TextBlock x:Name="RightGitStatus" FontSize="12" Opacity="0.8"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="TopEdgeAlignedRight">
                                    <StackPanel Width="320" Spacing="12" Padding="4">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8AD;" FontSize="14"
                                                          Foreground="{ThemeResource SpanAccentBrush}"/>
                                                <TextBlock x:Name="RightFlyoutBranch" FontSize="14"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <TextBlock x:Name="RightFlyoutStatus" FontSize="12" Opacity="0.8"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="RightFlyoutCommitsLabel" FontSize="11"
                                                       FontWeight="SemiBold" Opacity="0.6"/>
                                            <TextBlock x:Name="RightFlyoutCommits"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="RightFlyoutFilesLabel" FontSize="11"
                                                       FontWeight="SemiBold" Opacity="0.6"/>
                                            <ScrollViewer MaxHeight="200">
                                                <TextBlock x:Name="RightFlyoutFiles"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="11"/>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Border>

                    <!-- Right Pane Path Bar — split mode only. Same pattern as LeftPanePathBar
                         but bound to RightExplorer so the breadcrumb tracks the right pane's
                         own current path. -->
                    <appcontrols:LumiPanePathBar Grid.Row="3" Grid.ColumnSpan="3"
                                                 x:Name="RightPanePathBar"
                                                 Mode="Right"
                                                 Height="{StaticResource LumiPathBarHeight}"
                                                 PathSegments="{x:Bind ViewModel.RightExplorer.PathSegments, Mode=OneWay}"
                                                 Visibility="{x:Bind helpers:ConverterHelpers.BoolToVisibility(ViewModel.IsSplitViewEnabled), Mode=OneWay}"/>
                </Grid>

                <!-- Split divider (RightPaneContainer의 Margin="1,0,0,0"으로 생긴 1px 갭에 배치) -->
                <Border Grid.Column="2" Width="1" HorizontalAlignment="Left" IsHitTestVisible="False"
                        Background="{ThemeResource SpanAccentDimBrush}"
                        Visibility="{x:Bind IsSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}"/>
            </Grid>

            <!-- Sidebar edge shadow removed: splitter alone provides sufficient separation -->

        </Grid>

        <!-- 4. Status Bar (column 1, row 3) — Tahoe path bar tone (30px, dark overlay, hairline top divider) -->
        <!-- ============================================================
             4. PATH BAR (mockup _ui_mockup_v3_glass.html / V3.png)
             • height 30, padding 0 14, bg LumiPathBarBrush, hairline top divider
             • Single mode  : breadcrumb (LEFT) + status incl. disk space (RIGHT)
             • Split mode   : two side-by-side path bars (left+right pane).
                              Disk space text hidden (per spec); item-count and selection
                              status are shown for the ACTIVE pane only on the right edge.
             ============================================================ -->
        <Grid Grid.Column="1" Grid.Row="3" AutomationProperties.AutomationId="StatusBar"
              Height="{StaticResource LumiPathBarHeight}"
              Background="{ThemeResource LumiPathBarBrush}"
              BorderBrush="{ThemeResource LumiDividerSoftBrush}"
              BorderThickness="0,1,0,0"
              Padding="14,0"
              Visibility="{x:Bind helpers:ConverterHelpers.NotBoolToVisibility(ViewModel.IsSplitViewEnabled), Mode=OneWay}">

            <!-- ===== Single-pane mode ===== -->
            <Grid Visibility="{x:Bind helpers:ConverterHelpers.NotBoolToVisibility(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: breadcrumb (mockup spec) — folder icon + segment chip + chevron separator.
                     Bound to the existing ExplorerViewModel.PathSegments ObservableCollection (Models.PathSegment).
                     Each segment is clickable: NavigateToSegment(segment) jumps to that path. -->
                <ItemsControl x:Name="LumiPathBarItems" Grid.Column="0" VerticalAlignment="Center"
                              ItemsSource="{x:Bind ViewModel.ActiveExplorer.PathSegments, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:PathSegment">
                            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                                <Button Padding="6,3" MinWidth="0" MinHeight="0"
                                        Background="Transparent" BorderThickness="0"
                                        CornerRadius="{StaticResource LumiPathSegmentCornerRadius}"
                                        Click="OnLumiPathSegmentClick"
                                        Tag="{x:Bind FullPath}">
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="11"
                                                  Foreground="{ThemeResource LumiAmberBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind Name}"
                                                   FontFamily="{StaticResource LumiFontFamily}"
                                                   FontSize="{StaticResource LumiFontSizePathBar}"
                                                   Foreground="{ThemeResource LumiTextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="›" FontSize="9" Opacity="0.5"
                                           Foreground="{ThemeResource LumiTextTertiaryBrush}"
                                           Margin="2,0,2,0" VerticalAlignment="Center"
                                           Visibility="{x:Bind ChevronVisibility}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Right: status (item count · selection · disk space) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center"
                            BorderBrush="{ThemeResource LumiDividerBrush}" BorderThickness="1,0,0,0" Padding="12,0,0,0">
                    <TextBlock AutomationProperties.AutomationId="TextBlock_ItemCount"
                               Text="{x:Bind ViewModel.StatusItemCountText, Mode=OneWay}"
                               FontFamily="{StaticResource LumiFontFamily}"
                               FontSize="{StaticResource LumiFontSizePathStatus}"
                               Foreground="{ThemeResource LumiTextTertiaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusItemCountText), Mode=OneWay}"/>
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource LumiTextTertiaryBrush}" VerticalAlignment="Center"
                             Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusSelectionText), Mode=OneWay}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusSelectionText, Mode=OneWay}"
                               FontFamily="{StaticResource LumiFontFamily}"
                               FontSize="{StaticResource LumiFontSizePathStatus}"
                               Foreground="{ThemeResource LumiTextTertiaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusSelectionText), Mode=OneWay}"/>
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource LumiTextTertiaryBrush}" VerticalAlignment="Center"
                             Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusDiskSpaceText), Mode=OneWay}"/>
                    <TextBlock AutomationProperties.AutomationId="TextBlock_DiskSpace"
                               Text="{x:Bind ViewModel.StatusDiskSpaceText, Mode=OneWay}"
                               FontFamily="{StaticResource LumiFontFamily}"
                               FontSize="{StaticResource LumiFontSizePathStatus}"
                               Foreground="{ThemeResource LumiTextTertiaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusDiskSpaceText), Mode=OneWay}"/>
                </StackPanel>
            </Grid>

            <!-- Split mode: outer path bar is hidden (Visibility above). Each pane carries
                 its own path bar at the bottom row inside LeftPaneContainer / RightPaneContainer
                 so the breadcrumbs align with their own column area instead of the sidebar+content
                 outer grid. -->
        </Grid>

        <!-- File Operation Progress Panel (floating bottom-right, above content) -->
        <spancontrols:FileOperationProgressControl x:Name="FileOpProgressControl" AutomationProperties.AutomationId="FileOpProgress" Grid.Row="2"
                                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Canvas.ZIndex="100"
                                                    Margin="0,0,16,8"/>

        <!-- ===== FILE SHELF — Yoink-style floating overlay (right edge) ===== -->
        <Border x:Name="ShelfPanel" Grid.Row="2"
                HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Width="270" Canvas.ZIndex="150"
                Background="{ThemeResource SpanBgLayer1Brush}"
                BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1,0,0,0"
                Visibility="{x:Bind ViewModel.IsShelfPanelVisible, Mode=OneWay}"
                AllowDrop="True"
                DragOver="OnShelfDragOver" Drop="OnShelfDrop" DragLeave="OnShelfDragLeave"
                PointerExited="OnShelfPanelPointerExited" PointerEntered="OnShelfPanelPointerEntered"
                RenderTransformOrigin="1,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ShelfSlideTransform" X="0"/>
            </Border.RenderTransform>
            <!-- 너비 애니메이션을 위한 ScaleTransform (축소 모드: ScaleX=20/270) -->
            <Border.Resources>
                <Storyboard x:Name="ShelfShrinkStoryboard"/>
                <Storyboard x:Name="ShelfExpandStoryboard"/>
            </Border.Resources>
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>
            <Grid>
                <!-- 축소 배지 (ShelfCollapsed 모드에서만 표시) -->
                <Border x:Name="ShelfCollapsedBadge" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE8F1;" FontSize="14" Foreground="{ThemeResource SpanAccentBrush}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ShelfCollapsedCount" Text="0"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 전체 콘텐츠 (Full 모드) -->
                <Grid x:Name="ShelfFullContent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Item List -->
                    <RowDefinition Height="Auto"/> <!-- Actions -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Padding="12,10" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8F1;" FontSize="16" Foreground="{ThemeResource SpanAccentBrush}"/>
                        <TextBlock x:Name="ShelfCountText" Text="Shelf (0)" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SpanTextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Click="OnShelfClearClick"
                            Background="Transparent" BorderThickness="0"
                            Padding="4" Width="28" Height="28" MinWidth="0" MinHeight="0"
                            ToolTipService.ToolTip="Clear all">
                        <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                    </Button>
                    <Button Grid.Column="2" Click="OnShelfCloseClick"
                            Background="Transparent" BorderThickness="0"
                            Padding="4" Width="28" Height="28" MinWidth="0" MinHeight="0"
                            ToolTipService.ToolTip="Close shelf">
                        <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                    </Button>
                </Grid>

                <!-- Item List (vertical, multi-select) — Grid wrapper for RubberBandSelectionHelper -->
                <Grid x:Name="ShelfListViewGrid" Grid.Row="1">
                    <ListView x:Name="ShelfListView"
                              ItemsSource="{x:Bind ViewModel.ShelfItems, Mode=OneWay}"
                              SelectionMode="Extended" CanDragItems="True" Padding="4"
                              KeyDown="OnShelfListViewKeyDown"
                              DoubleTapped="OnShelfItemDoubleTapped"
                              DragItemsStarting="OnShelfDragItemsStarting"
                              DragItemsCompleted="OnShelfDragItemsCompleted">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ShelfItem">
                                <Grid Padding="8,6" ColumnSpacing="8"
                                      RightTapped="OnShelfItemRightTapped"
                                      PointerEntered="OnShelfItemPointerEntered"
                                      PointerExited="OnShelfItemPointerExited">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 아이콘 + 핀 배지 -->
                                    <Grid VerticalAlignment="Center">
                                        <FontIcon FontFamily="{StaticResource RemixIcons}"
                                                  Glyph="{x:Bind IconGlyph}" FontSize="16"
                                                  Foreground="{x:Bind IconBrush}"/>
                                        <!-- 핀 인디케이터 (잠금 시만 표시) -->
                                        <FontIcon Glyph="&#xE840;" FontSize="7"
                                                  Foreground="{ThemeResource SpanAccentBrush}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Top"
                                                  Margin="0,-3,-5,0"
                                                  Visibility="{x:Bind IsPinned, Mode=OneWay}"/>
                                    </Grid>

                                    <!-- 이름 + 경로 -->
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{ThemeResource SpanTextPrimaryBrush}"/>
                                        <TextBlock Text="{x:Bind SourceFolder}" FontSize="10"
                                                   TextTrimming="CharacterEllipsis" Opacity="0.6"
                                                   Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                                    </StackPanel>

                                    <!-- 호버 오버레이 버튼 (기본 숨김) -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2"
                                                VerticalAlignment="Center"
                                                Visibility="Collapsed" Tag="ShelfHoverButtons">
                                        <Button Tag="{x:Bind Id}" Click="OnShelfItemPinClick"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="2" Width="24" Height="24" MinWidth="0" MinHeight="0"
                                                ToolTipService.ToolTip="Pin">
                                            <FontIcon Glyph="&#xE718;" FontSize="10"
                                                      Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                                        </Button>
                                        <Button Tag="{x:Bind Id}" Click="OnShelfItemRemoveClick"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="2" Width="24" Height="24" MinWidth="0" MinHeight="0"
                                                ToolTipService.ToolTip="Remove">
                                            <FontIcon Glyph="&#xE711;" FontSize="10"
                                                      Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Empty state -->
                <StackPanel x:Name="ShelfEmptyHint" Grid.Row="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="8" Opacity="0.4">
                    <FontIcon Glyph="&#xE896;" FontSize="32"
                              Foreground="{ThemeResource SpanTextTertiaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Drop files here" FontSize="12"
                               Foreground="{ThemeResource SpanTextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2" Spacing="4" Padding="8,8"
                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0">
                    <Button x:Name="ShelfMoveHereButton" Click="OnShelfMoveHereClick"
                            Background="{ThemeResource SpanAccentBrush}"
                            Foreground="White" CornerRadius="4"
                            HorizontalAlignment="Stretch" Height="32"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8DE;" FontSize="13" Foreground="White"/>
                            <TextBlock x:Name="ShelfMoveText" Text="Move here" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ShelfCopyHereButton" Click="OnShelfCopyHereClick"
                            Background="{ThemeResource SpanBgLayer2Brush}"
                            CornerRadius="4"
                            HorizontalAlignment="Stretch" Height="32"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8C8;" FontSize="13" Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                            <TextBlock x:Name="ShelfCopyText" Text="Copy here" FontSize="12"
                                       Foreground="{ThemeResource SpanTextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                </Grid> <!-- /ShelfFullContent -->
            </Grid>
        </Border>

        <!-- Command Palette Overlay (Ctrl+K) -->
        <Grid x:Name="CommandPaletteOverlay" Grid.RowSpan="5" Visibility="Collapsed"
              Canvas.ZIndex="250"
              Background="#40000000"
              PointerPressed="OnCommandPaletteOverlayPointerPressed">
            <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,80,0,0" Width="560"
                    Background="{ThemeResource SpanBgLayer1Brush}"
                    BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="0">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Input -->
                    <TextBox x:Name="CommandPaletteInput"
                             PlaceholderText="Type a command or search..."
                             FontSize="14" Padding="12,10"
                             Background="Transparent" BorderThickness="0"
                             TextChanged="OnCommandPaletteInputTextChanged"
                             KeyDown="OnCommandPaletteInputKeyDown"/>

                    <Rectangle Grid.Row="1" Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}"/>

                    <!-- Results List -->
                    <ListView x:Name="CommandPaletteList" Grid.Row="2"
                              MaxHeight="420"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              ItemClick="OnCommandPaletteItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:CommandPaletteItem">
                                <Grid Padding="12,8" ColumnSpacing="10" Opacity="{x:Bind Opacity}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="14"
                                              Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontSize="13"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource SpanTextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind Category}" FontSize="11"
                                               Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                               VerticalAlignment="Center" Opacity="0.7"/>
                                    <Border Grid.Column="3" Background="{ThemeResource SpanBgLayer2Brush}"
                                            CornerRadius="4" Padding="6,2"
                                            Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(Shortcut)}">
                                        <TextBlock Text="{x:Bind Shortcut}" FontSize="11"
                                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                   FontFamily="Consolas"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- No Results -->
                    <TextBlock x:Name="CommandPaletteNoResults" Grid.Row="2"
                               Text="No results found" FontSize="13"
                               Foreground="{ThemeResource SpanTextTertiaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,20" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Help Overlay (Shift+? / F1) -->
        <Grid x:Name="HelpOverlay" AutomationProperties.AutomationId="HelpOverlay" Grid.RowSpan="4" Visibility="Collapsed"
              Canvas.ZIndex="200"
              Background="#80000000"
              PointerPressed="HelpOverlay_PointerPressed">
            <views:HelpFlyoutContent x:Name="HelpFlyoutContentControl" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Margin="40"/>
        </Grid>

        <!-- Toast Notification Overlay -->
        <Border x:Name="ToastOverlay" Grid.Row="2"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,16" Padding="16,10"
                Background="{ThemeResource SpanBgLayer1Brush}"
                BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1"
                CornerRadius="8" Opacity="0" IsHitTestVisible="False"
                RenderTransformOrigin="0.5,1">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="20"/>
            </Border.RenderTransform>
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon x:Name="ToastIcon" Glyph="&#xE73E;" FontSize="14"
                          Foreground="{ThemeResource SpanAccentBrush}"/>
                <TextBlock x:Name="ToastText" Text="" FontSize="13"
                           Foreground="{ThemeResource SpanTextPrimaryBrush}"
                           VerticalAlignment="Center" MaxWidth="500"
                           TextWrapping="WrapWholeWords"/>
            </StackPanel>
        </Border>
    </Grid>
        </Border>
    </Grid>
</Window>
