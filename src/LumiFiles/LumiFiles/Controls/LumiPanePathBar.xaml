<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LumiFiles.Controls.LumiPanePathBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LumiFiles.Models"
    HorizontalAlignment="Stretch"
    Background="{ThemeResource LumiPathBarBrush}"
    BorderBrush="{ThemeResource LumiDividerSoftBrush}"
    BorderThickness="0,1,0,0"
    Padding="14,0">
    <Grid>
        <!-- Scrollable breadcrumb. When path overflows the pane width the user
             can still drag-scroll horizontally; OverflowIndicator below shows a
             gradient mask + ellipsis on the left so the cut-off is visually
             explicit. Pattern ported from AddressBarControl (Stage S-3.4). -->
        <ScrollViewer x:Name="SegmentsScroller"
                      HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Auto" VerticalScrollMode="Disabled"
                      VerticalContentAlignment="Center"
                      SizeChanged="OnScrollerSizeChanged"
                      ViewChanged="OnScrollerViewChanged">
            <ItemsControl x:Name="SegmentsHost"
                          ItemsSource="{x:Bind PathSegments, Mode=OneWay}"
                          SizeChanged="OnContentSizeChanged"
                          VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="0"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:PathSegment">
                        <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                            <Button Padding="6,3" MinWidth="0" MinHeight="0"
                                    Background="Transparent" BorderThickness="0"
                                    CornerRadius="{StaticResource LumiPathSegmentCornerRadius}"
                                    Click="OnSegmentClick"
                                    Tag="{x:Bind FullPath}">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="11"
                                              Foreground="{ThemeResource LumiPanePathIconBrush}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Name}"
                                               FontFamily="{StaticResource LumiFontFamily}"
                                               FontSize="{StaticResource LumiFontSizePathBar}"
                                               Foreground="{ThemeResource LumiTextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="›" FontSize="9" Opacity="0.5"
                                       Foreground="{ThemeResource LumiTextTertiaryBrush}"
                                       Margin="2,0,2,0" VerticalAlignment="Center"
                                       Visibility="{x:Bind ChevronVisibility}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Overflow indicator — pinned to the LEFT edge of the scroller so it
             only paints when content is scrolled past origin (parent path is
             hidden). IsHitTestVisible=False so segment clicks still pass
             through. Gradient fades to transparent at the right edge so the
             first visible segment isn't fully obscured. -->
        <Border x:Name="OverflowIndicator" HorizontalAlignment="Left"
                VerticalAlignment="Stretch" Visibility="Collapsed"
                IsHitTestVisible="False" Padding="6,0,18,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#CC000000" Offset="0"/>
                    <GradientStop Color="#CC000000" Offset="0.55"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="&#x2026;"
                       FontSize="{StaticResource LumiFontSizePathBar}"
                       FontFamily="{StaticResource LumiFontFamily}"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource LumiTextTertiaryBrush}"/>
        </Border>
    </Grid>
</UserControl>
