<Window
    x:Class="LumiFiles.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:LumiFiles.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- ============================================================
         LUMI SETTINGS — Separate borderless rounded glass window.
         Mirrors MainWindow's outer composition (WallpaperRoot →
         WindowFrame → 2-col Grid with sidebar in col 0, caption +
         content in col 1). The SettingsView UserControl owns the
         actual sidebar visuals (LumiSidebar styled) and content; this
         window adds only the right-side caption overlay (close button)
         on top of the SettingsView, mirroring MainWindow's AppTitleBar
         placement (column 1, row 0).
         FIXED SIZE: 1000 x 750. No resize handles.
         ============================================================ -->
    <Grid x:Name="WallpaperRoot">
        <Rectangle Fill="{ThemeResource LumiWallpaperBaseBrush}"/>
        <!-- S-3.34 Tier 2 (rev 2): BorderThickness 1.5 → 2. -->
        <Border x:Name="WindowFrame"
                CornerRadius="{StaticResource LumiWindowCornerRadius}"
                Margin="{StaticResource LumiWindowPadding}"
                Background="{ThemeResource LumiWindowFrameBrush}"
                BorderBrush="{ThemeResource LumiWindowHairlineBrush}"
                BorderThickness="2"
                UseLayoutRounding="True">
            <Grid x:Name="RootGrid" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource LumiSidebarGridWidth}"/>  <!-- sidebar (provided by SettingsView) -->
                    <ColumnDefinition Width="*"/>                                       <!-- content -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>   <!-- Caption bar (drag region + close) -->
                    <RowDefinition Height="*"/>    <!-- Settings content -->
                </Grid.RowDefinitions>

                <!-- ============================================================
                     SETTINGS VIEW — embeds the existing UserControl unchanged.
                     SettingsView spans BOTH columns and BOTH rows: its inner
                     Grid lays out the LumiSidebar in column 0 (full height) and
                     the content in column 1 (with a 36 px top margin reserved
                     for the caption overlay below).
                     ============================================================ -->
                <views:SettingsModeView x:Name="SettingsView"
                                        Grid.Column="0" Grid.ColumnSpan="2"
                                        Grid.Row="0" Grid.RowSpan="2"/>

                <!-- ============================================================
                     CAPTION BAR — column 1 row 0 only (mirrors MainWindow's
                     AppTitleBar position: above content, right of sidebar).
                     Transparent drag region with the close button anchored to
                     the right. Z-order: declared after SettingsView so it
                     paints on top.
                     ============================================================ -->
                <Grid x:Name="AppTitleBar" Grid.Column="1" Grid.Row="0" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Close button (custom hover: red bg + white glyph) -->
                    <Button x:Name="CaptionCloseButton"
                            Grid.Column="1"
                            Width="46" Height="32" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            CornerRadius="0"
                            VerticalAlignment="Top"
                            ToolTipService.ToolTip="닫기"
                            Click="OnCaptionCloseClick">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E81123"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#F1707A"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                        </Button.Resources>
                        <FontIcon Glyph="&#xE8BB;" FontSize="10"
                                  FontFamily="Segoe Fluent Icons"
                                  Foreground="{ThemeResource LumiTextTertiaryBrush}"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
