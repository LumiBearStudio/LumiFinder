<Application
    x:Class="LumiFiles.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LumiFiles"
    xmlns:helpers="using:LumiFiles.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="/Assets/Styles/Icons.xaml"/>
                <!-- Tahoe Liquid Glass tokens (matches _ui_mockup_v3_glass.html) -->
                <ResourceDictionary Source="/Assets/Styles/LumiTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ============================================================
                 Theme Dictionaries: Dark / Light color tokens
                 ============================================================ -->
            <ResourceDictionary.ThemeDictionaries>

                <!-- ==================== DARK THEME ==================== -->
                <ResourceDictionary x:Key="Dark">
                    <!-- Backgrounds — keyed to the sidebar gradient (LumiSidebarBrush =
                         #1E1C28 → #161420). Layer1 picks up the sidebar's top tone (opaque),
                         Layer2 sits one step lighter (column headers, sublayers), Layer3 a
                         shade lighter still. Same purple-warm hue family so DetailsModeView
                         and PreviewPanelView read as a continuation of the sidebar instead
                         of the cool gray Span original. -->
                    <Color x:Key="SpanBgMicaColor">#0F0E14</Color>
                    <Color x:Key="SpanBgLayer1Color">#1E1C28</Color>
                    <Color x:Key="SpanBgLayer2Color">#26242E</Color>
                    <Color x:Key="SpanBgLayer3Color">#2E2C38</Color>
                    <Color x:Key="SpanBgLayer2TransparentColor">#0026242E</Color>

                    <!-- Accent — rebranded from Span's Win11 blue (#60cdff) to LumiFiles amber.
                         Drives every Span*Accent* brush usage (file icons, link emblems, hover
                         highlights, etc.) so legacy views (DetailsModeView, PreviewPanelView)
                         pick up the LumiFiles golden-brown tone without per-view edits. -->
                    <Color x:Key="SpanAccentColor">#FFB86B</Color>
                    <Color x:Key="SpanAccentHoverColor">#FFC988</Color>
                    <Color x:Key="SpanAccentDimColor">#B3FFB86B</Color>

                    <!-- Text — rebranded to LumiFiles dark-mode text scale (LumiTextPrimary
                         #EEEEF2 / Secondary #92929A / Tertiary #60606A) so Span* legacy text
                         tones match the rest of the app. -->
                    <Color x:Key="SpanTextPrimaryColor">#EEEEF2</Color>
                    <Color x:Key="SpanTextSecondaryColor">#92929A</Color>
                    <Color x:Key="SpanTextTertiaryColor">#60606A</Color>
                    <Color x:Key="SpanTextDisabledColor">#3E3E45</Color>

                    <!-- Solid Brushes -->
                    <SolidColorBrush x:Key="SpanBgMicaBrush" Color="{StaticResource SpanBgMicaColor}" />
                    <SolidColorBrush x:Key="SpanBgLayer1Brush" Color="{StaticResource SpanBgLayer1Color}" />
                    <SolidColorBrush x:Key="SpanBgLayer2Brush" Color="{StaticResource SpanBgLayer2Color}" />
                    <SolidColorBrush x:Key="SpanBgLayer3Brush" Color="{StaticResource SpanBgLayer3Color}" />
                    <SolidColorBrush x:Key="SpanAccentBrush" Color="{StaticResource SpanAccentColor}" />
                    <SolidColorBrush x:Key="SpanAccentHoverBrush" Color="{StaticResource SpanAccentHoverColor}" />
                    <SolidColorBrush x:Key="SpanAccentDimBrush" Color="{StaticResource SpanAccentDimColor}" />

                    <SolidColorBrush x:Key="SpanTextPrimaryBrush" Color="{StaticResource SpanTextPrimaryColor}" />
                    <SolidColorBrush x:Key="SpanTextSecondaryBrush" Color="{StaticResource SpanTextSecondaryColor}" />
                    <SolidColorBrush x:Key="SpanTextTertiaryBrush" Color="{StaticResource SpanTextTertiaryColor}" />
                    <SolidColorBrush x:Key="SpanTextDisabledBrush" Color="{StaticResource SpanTextDisabledColor}" />

                    <!-- Translucent Brushes (accent-tinted, Windows Explorer style) -->
                    <SolidColorBrush x:Key="SpanBgHoverBrush" Color="#0F60CDFF" />
                    <SolidColorBrush x:Key="SpanBgActiveBrush" Color="#1A60CDFF" />
                    <SolidColorBrush x:Key="SpanBgSelectedBrush" Color="#2560CDFF" />
                    <SolidColorBrush x:Key="SpanBgSelectedHoverBrush" Color="#3060CDFF" />
                    <!-- Path highlight: border line for navigation breadcrumb items (not background fill) -->
                    <SolidColorBrush x:Key="SpanPathHighlightBrush" Color="#6060CDFF" />

                    <!-- Override WinUI system ListView/GridView selection colors -->
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#2560CDFF" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#3060CDFF" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#1A60CDFF" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelected" Color="#2560CDFF" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelectedPointerOver" Color="#3060CDFF" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelectedPressed" Color="#1A60CDFF" />

                    <!-- Override WinUI TextBox/AutoSuggestBox focus bottom line -->
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource SpanAccentColor}" />

                    <!-- Rubber-band selection -->
                    <SolidColorBrush x:Key="SpanSelectionRectFillBrush" Color="{StaticResource SpanAccentColor}" Opacity="0.15" />
                    <SolidColorBrush x:Key="SpanSelectionRectStrokeBrush" Color="{StaticResource SpanAccentColor}" Opacity="0.6" />

                    <!-- Borders (white overlay for dark) -->
                    <SolidColorBrush x:Key="SpanBorderSubtleBrush" Color="#0FFFFFFF" />
                    <SolidColorBrush x:Key="SpanBorderCardBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="SpanBorderControlBrush" Color="#1AFFFFFF" />

                    <!-- Global FocusVisual: 액센트 톤 얇은 포커스 링 (기본 흰+검 2px → 액센트 1px) -->
                    <SolidColorBrush x:Key="SystemControlFocusVisualPrimaryBrush" Color="{StaticResource SpanAccentDimColor}" />
                    <SolidColorBrush x:Key="SystemControlFocusVisualSecondaryBrush" Color="Transparent" />

                    <!-- Depth shadows (Miller column + sidebar edge) -->
                    <LinearGradientBrush x:Key="SpanColumnShadowBrush" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#1C000000" Offset="1"/>
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="SpanSidebarShadowBrush" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1C000000" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>

                    <!-- ============================================================
                         S-3.36 Dark theme: AccentButton 토큰을 Lumi Amber로 override.
                         Application.Resources 최상위에서는 XamlControlsResources의 동명
                         Dark theme dict 정의에 가려지므로 반드시 이 블록 안에서 정의해야 한다.
                         ============================================================ -->
                    <!-- Legacy AccentButton tokens (WinUI 3 ≤ 1.4) — literal hex로 단순화하여
                         StaticResource scope 이슈 회피. -->
                    <SolidColorBrush x:Key="AccentButtonBackground" Color="#FFFFB86B" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#FFFFD27A" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#FFD48028" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#33FFB86B" />
                    <SolidColorBrush x:Key="AccentButtonForeground" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="AccentButtonForegroundDisabled" Color="#7F1A1A1F" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrushPressed" Color="Transparent" />

                    <!-- Modern Fluent AccentFillColor tokens (WinUI 3 ≥ 1.5) — Legacy 토큰만으로
                         override 안 잡히는 경우 대비. AccentButtonBackground는 내부적으로
                         {ThemeResource AccentFillColorDefaultBrush}를 가리키도록 변경된 케이스가 있다. -->
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#FFFFB86B" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#FFFFD27A" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#FFD48028" />
                    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#33FFB86B" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="#7F1A1A1F" />
                    <!-- 토글스위치/체크박스 등에서도 같은 액센트 사용 -->
                    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#FFFFB86B" />
                    <SolidColorBrush x:Key="SystemAccentColorLight2" Color="#FFFFD27A" />
                    <Color x:Key="SystemAccentColor">#FFFFB86B</Color>
                    <Color x:Key="SystemAccentColorDark1">#FFD48028</Color>
                    <Color x:Key="SystemAccentColorLight1">#FFFFD27A</Color>

                    <!-- 다이얼로그 전용 — LumiSidebarBrush보다 훨씬 불투명한 글래스 (반투명 약간만).
                         #1E1C28 / #161420 위에 알파 0xF0(94%) → 거의 솔리드. -->
                    <LinearGradientBrush x:Key="LumiDialogBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#F01E1C28" />
                        <GradientStop Offset="1" Color="#F5161420" />
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="ContentDialogBackground" Color="#F01E1C28" />
                </ResourceDictionary>

                <!-- ==================== LIGHT THEME ==================== -->
                <ResourceDictionary x:Key="Light">
                    <!-- Backgrounds (WinUI 3 Fluent tone-matched) -->
                    <Color x:Key="SpanBgMicaColor">#F3F3F3</Color>
                    <Color x:Key="SpanBgLayer1Color">#F9F9F9</Color>
                    <Color x:Key="SpanBgLayer2Color">#F3F3F3</Color>
                    <Color x:Key="SpanBgLayer3Color">#E6E6E6</Color>
                    <Color x:Key="SpanBgLayer2TransparentColor">#00F3F3F3</Color>

                    <!-- Accent -->
                    <Color x:Key="SpanAccentColor">#0078D4</Color>
                    <Color x:Key="SpanAccentHoverColor">#106EBE</Color>
                    <Color x:Key="SpanAccentDimColor">#B30078D4</Color>

                    <!-- Text -->
                    <Color x:Key="SpanTextPrimaryColor">#1B1B1B</Color>
                    <Color x:Key="SpanTextSecondaryColor">#616161</Color>
                    <Color x:Key="SpanTextTertiaryColor">#8B8B8B</Color>
                    <Color x:Key="SpanTextDisabledColor">#C4C4C4</Color>

                    <!-- Solid Brushes -->
                    <SolidColorBrush x:Key="SpanBgMicaBrush" Color="{StaticResource SpanBgMicaColor}" />
                    <SolidColorBrush x:Key="SpanBgLayer1Brush" Color="{StaticResource SpanBgLayer1Color}" />
                    <SolidColorBrush x:Key="SpanBgLayer2Brush" Color="{StaticResource SpanBgLayer2Color}" />
                    <SolidColorBrush x:Key="SpanBgLayer3Brush" Color="{StaticResource SpanBgLayer3Color}" />
                    <SolidColorBrush x:Key="SpanAccentBrush" Color="{StaticResource SpanAccentColor}" />
                    <SolidColorBrush x:Key="SpanAccentHoverBrush" Color="{StaticResource SpanAccentHoverColor}" />
                    <SolidColorBrush x:Key="SpanAccentDimBrush" Color="{StaticResource SpanAccentDimColor}" />

                    <SolidColorBrush x:Key="SpanTextPrimaryBrush" Color="{StaticResource SpanTextPrimaryColor}" />
                    <SolidColorBrush x:Key="SpanTextSecondaryBrush" Color="{StaticResource SpanTextSecondaryColor}" />
                    <SolidColorBrush x:Key="SpanTextTertiaryBrush" Color="{StaticResource SpanTextTertiaryColor}" />
                    <SolidColorBrush x:Key="SpanTextDisabledBrush" Color="{StaticResource SpanTextDisabledColor}" />

                    <!-- Translucent Brushes (accent-tinted, Windows Explorer style) -->
                    <SolidColorBrush x:Key="SpanBgHoverBrush" Color="#0F0078D4" />
                    <SolidColorBrush x:Key="SpanBgActiveBrush" Color="#1A0078D4" />
                    <SolidColorBrush x:Key="SpanBgSelectedBrush" Color="#250078D4" />
                    <SolidColorBrush x:Key="SpanBgSelectedHoverBrush" Color="#300078D4" />
                    <!-- Path highlight: border line for navigation breadcrumb items (not background fill) -->
                    <SolidColorBrush x:Key="SpanPathHighlightBrush" Color="#600078D4" />

                    <!-- Override WinUI system ListView/GridView selection colors -->
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#250078D4" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#300078D4" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#1A0078D4" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelected" Color="#250078D4" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelectedPointerOver" Color="#300078D4" />
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelectedPressed" Color="#1A0078D4" />

                    <!-- Override WinUI TextBox/AutoSuggestBox focus bottom line -->
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource SpanAccentColor}" />

                    <!-- Rubber-band selection -->
                    <SolidColorBrush x:Key="SpanSelectionRectFillBrush" Color="{StaticResource SpanAccentColor}" Opacity="0.15" />
                    <SolidColorBrush x:Key="SpanSelectionRectStrokeBrush" Color="{StaticResource SpanAccentColor}" Opacity="0.6" />

                    <!-- Borders (black overlay for light) -->
                    <SolidColorBrush x:Key="SpanBorderSubtleBrush" Color="#0F000000" />
                    <SolidColorBrush x:Key="SpanBorderCardBrush" Color="#14000000" />
                    <SolidColorBrush x:Key="SpanBorderControlBrush" Color="#1A000000" />

                    <!-- Global FocusVisual: 액센트 톤 얇은 포커스 링 -->
                    <SolidColorBrush x:Key="SystemControlFocusVisualPrimaryBrush" Color="{StaticResource SpanAccentDimColor}" />
                    <SolidColorBrush x:Key="SystemControlFocusVisualSecondaryBrush" Color="Transparent" />

                    <!-- Depth shadows (Miller column + sidebar edge) -->
                    <LinearGradientBrush x:Key="SpanColumnShadowBrush" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#0C000000" Offset="1"/>
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="SpanSidebarShadowBrush" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0C000000" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>

                    <!-- S-3.36 Light theme: 다크 글래스 디자인을 그대로 적용 (Lumi 디자인은 다크 기본). -->
                    <SolidColorBrush x:Key="AccentButtonBackground" Color="#FFFFB86B" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#FFFFD27A" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#FFD48028" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#33FFB86B" />
                    <SolidColorBrush x:Key="AccentButtonForeground" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="AccentButtonForegroundDisabled" Color="#7F1A1A1F" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrushPressed" Color="Transparent" />

                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#FFFFB86B" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#FFFFD27A" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#FFD48028" />
                    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#33FFB86B" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#FF1A1A1F" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="#7F1A1A1F" />
                    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#FFFFB86B" />
                    <SolidColorBrush x:Key="SystemAccentColorLight2" Color="#FFFFD27A" />
                    <Color x:Key="SystemAccentColor">#FFFFB86B</Color>
                    <Color x:Key="SystemAccentColorDark1">#FFD48028</Color>
                    <Color x:Key="SystemAccentColorLight1">#FFFFD27A</Color>

                    <LinearGradientBrush x:Key="LumiDialogBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#F01E1C28" />
                        <GradientStop Offset="1" Color="#F5161420" />
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="ContentDialogBackground" Color="#F01E1C28" />
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>

            <!-- ============================================================
                 Theme-Independent Resources
                 ============================================================ -->

            <!-- FontScale: 전역 폰트 스케일 서비스 (Single Source of Truth).
                 모든 XAML의 {Binding Source={StaticResource FontScale}, Path=...} 가 이 인스턴스를 참조.
                 FontScaleService.Instance (C#) 는 Application.Current.Resources["FontScale"] 을 읽어
                 XAML 파서가 만든 이 인스턴스와 동일한 객체를 반환한다. -->
            <helpers:FontScaleService x:Key="FontScale"/>

            <!-- Dimensions -->
            <x:Double x:Key="TitleBarHeight">40</x:Double>
            <x:Double x:Key="CommandBarHeight">44</x:Double>
            <x:Double x:Key="AddressBarHeight">38</x:Double>
            <x:Double x:Key="StatusBarHeight">28</x:Double>
            <x:Double x:Key="SidebarWidth">200</x:Double>
            <x:Double x:Key="MillerColumnWidth">220</x:Double>
            <x:Double x:Key="PreviewWidth">280</x:Double>

            <CornerRadius x:Key="RadiusSm">4</CornerRadius>
            <CornerRadius x:Key="RadiusMd">6</CornerRadius>
            <CornerRadius x:Key="RadiusLg">8</CornerRadius>
            <CornerRadius x:Key="RadiusXl">12</CornerRadius>

            <!-- Fonts -->
            <FontFamily x:Key="FluentIcons">Segoe Fluent Icons</FontFamily>
            <FontFamily x:Key="RemixIcons">/Assets/Fonts/remixicon.ttf#RemixIcon, /Assets/Fonts/remixicon.ttf#remixicon</FontFamily>
            <FontFamily x:Key="AppFont">Segoe UI Variable, Segoe UI, Malgun Gothic, Microsoft YaHei UI, Microsoft JhengHei UI, Yu Gothic UI</FontFamily>
            <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, Malgun Gothic, Microsoft YaHei UI, Microsoft JhengHei UI, Yu Gothic UI</FontFamily>

            <!-- ============================================================
                 S-3.36 (Tier 1+2): MenuFlyout 전역 Lumi 스타일
                 - 시스템 기본 회색 메뉴를 LumiSidebar 글래스 톤으로 통일.
                 - Theme-independent (Application.Resources 최상위) — Dark/Light 모두 적용.
                   Lumi 디자인 자체가 다크 글래스 기반이므로 라이트 테마에서도 동일한
                   Lumi 톤 메뉴가 표시된다.
                 - 적용 범위: 사이드바 우클릭, 파일/폴더 우클릭, 탭 우클릭, Shelf,
                   주소바, Tray icon, 정렬/뷰모드 드롭다운 — 모든 MenuFlyout 동시.
                 ============================================================ -->

            <!-- Theme-resource overrides for MenuFlyoutItem visual states -->
            <SolidColorBrush x:Key="MenuFlyoutItemBackground" Color="Transparent" />
            <StaticResource x:Key="MenuFlyoutItemBackgroundPointerOver" ResourceKey="LumiHoverBrush" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPressed" Color="#1FFFFFFF" />
            <StaticResource x:Key="MenuFlyoutItemForeground" ResourceKey="LumiTextPrimaryBrush" />
            <StaticResource x:Key="MenuFlyoutItemForegroundPointerOver" ResourceKey="LumiTextPrimaryBrush" />
            <StaticResource x:Key="MenuFlyoutItemForegroundPressed" ResourceKey="LumiTextPrimaryBrush" />
            <StaticResource x:Key="MenuFlyoutItemForegroundDisabled" ResourceKey="LumiTextTertiaryBrush" />
            <StaticResource x:Key="MenuFlyoutSeparatorThemeBrush" ResourceKey="LumiDividerSoftBrush" />
            <StaticResource x:Key="MenuFlyoutItemKeyboardAcceleratorTextForeground" ResourceKey="LumiTextSecondaryBrush" />
            <StaticResource x:Key="MenuFlyoutItemKeyboardAcceleratorTextForegroundPointerOver" ResourceKey="LumiTextSecondaryBrush" />
            <StaticResource x:Key="MenuFlyoutItemKeyboardAcceleratorTextForegroundPressed" ResourceKey="LumiTextSecondaryBrush" />
            <StaticResource x:Key="MenuFlyoutSubItemBackgroundSubMenuOpened" ResourceKey="LumiHoverBrush" />
            <StaticResource x:Key="MenuFlyoutSubItemForegroundSubMenuOpened" ResourceKey="LumiTextPrimaryBrush" />
            <StaticResource x:Key="MenuFlyoutSubItemChevron" ResourceKey="LumiTextSecondaryBrush" />
            <StaticResource x:Key="MenuFlyoutSubItemChevronPointerOver" ResourceKey="LumiTextPrimaryBrush" />

            <!-- Implicit Style (no x:Key) — applies to ALL MenuFlyoutPresenter automatically.
                 WinUI 3 popups가 Application.Resources implicit style를 인식하지만 일부 케이스에서
                 누락 위험이 있어 named 'LumiMenuFlyoutPresenterStyle'도 함께 정의 (코드 측에서 명시 적용 가능). -->
            <Style TargetType="MenuFlyoutPresenter" x:Key="LumiMenuFlyoutPresenterStyle">
                <Setter Property="Background" Value="{ThemeResource LumiSidebarBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource LumiEdgeSideBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource LumiSidebarCornerRadius}" />
                <Setter Property="Padding" Value="4" />
                <Setter Property="MinWidth" Value="200" />
                <Setter Property="FontFamily" Value="{StaticResource LumiFontFamily}" />
                <Setter Property="FontSize" Value="{StaticResource LumiFontSizeBase}" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>
            <Style TargetType="MenuFlyoutPresenter" BasedOn="{StaticResource LumiMenuFlyoutPresenterStyle}"/>

            <!-- Implicit MenuFlyoutItem Style — corner radius for hover highlight + tighter padding -->
            <Style TargetType="MenuFlyoutItem">
                <Setter Property="CornerRadius" Value="{StaticResource LumiSidebarItemCornerRadius}" />
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="FontFamily" Value="{StaticResource LumiFontFamily}" />
                <Setter Property="FontSize" Value="{StaticResource LumiFontSizeBase}" />
            </Style>

            <Style TargetType="ToggleMenuFlyoutItem">
                <Setter Property="CornerRadius" Value="{StaticResource LumiSidebarItemCornerRadius}" />
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="FontFamily" Value="{StaticResource LumiFontFamily}" />
                <Setter Property="FontSize" Value="{StaticResource LumiFontSizeBase}" />
            </Style>

            <Style TargetType="MenuFlyoutSubItem">
                <Setter Property="CornerRadius" Value="{StaticResource LumiSidebarItemCornerRadius}" />
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="FontFamily" Value="{StaticResource LumiFontFamily}" />
                <Setter Property="FontSize" Value="{StaticResource LumiFontSizeBase}" />
            </Style>

            <!-- ============================================================
                 S-3.36 (실제 적용 대상): ContentDialog 전역 Lumi 스타일.
                 사용자가 의도한 "사이드바에서 나오는 창" = OnBrowseNetworkTapped /
                 OnConnectToServerTapped 등 18개의 ContentDialog. 시스템 기본
                 회색 다이얼로그 + 파란 액센트 버튼을 LumiSidebar 글래스 + Amber
                 액센트로 통일.
                 ============================================================ -->

            <!-- ContentDialog 본체 ThemeResource 오버라이드 -->
            <StaticResource x:Key="ContentDialogBackground" ResourceKey="LumiSidebarBrush" />
            <StaticResource x:Key="ContentDialogForeground" ResourceKey="LumiTextPrimaryBrush" />
            <StaticResource x:Key="ContentDialogBorderBrush" ResourceKey="LumiEdgeSideBrush" />
            <SolidColorBrush x:Key="ContentDialogTopOverlay" Color="Transparent" />
            <StaticResource x:Key="ContentDialogSeparatorBorderBrush" ResourceKey="LumiDividerSoftBrush" />

            <!-- ⚠ ContentDialogButtonBackground override는 WinUI 3에서 Primary 버튼까지 덮어
                 AccentButton의 amber 색상을 가린다. 따라서 제거 — 비-Primary는 시스템 기본 사용,
                 Primary는 AccentButton 토큰(아래 ThemeDictionaries에 정의)이 적용된다. -->
            <!-- (ContentDialogButton* removed) -->

            <!-- NOTE: AccentButton 토큰 (AccentButtonBackground 등)은 Application.Resources 최상위에
                 두면 XamlControlsResources의 ThemeDictionaries[Dark/Light]에 있는 동명 키에 가려진다.
                 따라서 아래 ThemeDictionaries Dark/Light 블록 안으로 이동시켜 우선순위 확보. -->
            <!-- (AccentButton overrides moved to ThemeDictionaries below) -->

            <!-- 다이얼로그 외곽 모서리/패딩/그림자 — Background는 LumiDialogBackgroundBrush
                 (LumiSidebarBrush보다 훨씬 불투명한 글래스, 반투명 약간만 유지). -->
            <Style TargetType="ContentDialog" x:Key="LumiContentDialogStyle">
                <Setter Property="Background" Value="{ThemeResource LumiDialogBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource LumiEdgeSideBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource LumiSidebarCornerRadius}" />
                <Setter Property="FontFamily" Value="{StaticResource LumiFontFamily}" />
                <Setter Property="Foreground" Value="{ThemeResource LumiTextPrimaryBrush}" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>
            <Style TargetType="ContentDialog" BasedOn="{StaticResource LumiContentDialogStyle}"/>

            <!-- Styles -->

            <!-- Unified Button Style (Command Bar Icons) -->
            <Style x:Key="UnifiedButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
                <Setter Property="Foreground" Value="{ThemeResource SpanTextSecondaryBrush}" />
                <Setter Property="helpers:CursorHelper.IsHandCursor" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid" Background="Transparent" CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualStateGroup.Transitions>
                                            <VisualTransition GeneratedDuration="0:0:0.15">
                                                <VisualTransition.GeneratedEasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </VisualTransition.GeneratedEasingFunction>
                                            </VisualTransition>
                                        </VisualStateGroup.Transitions>
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="StateOverlay" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SpanBgHoverBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetName="StateOverlay" Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0" />
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SpanTextPrimaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="StateOverlay" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SpanBgActiveBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetName="StateOverlay" Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0" />
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SpanTextPrimaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.3" Duration="0" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Border x:Name="StateOverlay" Background="Transparent" Opacity="0"
                                        CornerRadius="{TemplateBinding CornerRadius}" />
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTransitions="{TemplateBinding ContentTransitions}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Padding="{TemplateBinding Padding}"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  AutomationProperties.AccessibilityView="Raw" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
